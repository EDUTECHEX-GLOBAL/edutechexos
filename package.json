{
  "name": "edutechexos",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "concurrently -n frontend,backend \"npm run dev:frontend\" \"npm run dev:backend\"",
    "dev:frontend": "npm run dev --workspace=@edutechexos/frontend",
    "dev:backend": "npm run dev --workspace=@edutechexos/backend",
    "build": "npm run build --workspace=@edutechexos/frontend",
    "start": "npm run start --workspace=@edutechexos/frontend",
    "lint": "npm run lint --workspace=@edutechexos/frontend",
    "lint:fix": "npm run lint:fix --workspace=@edutechexos/frontend",
    "format": "prettier --write \"packages/**/*.{ts,tsx,css,md,json}\"",
    "type-check": "npm run type-check --workspace=@edutechexos/frontend"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "nodemon": "^3.1.0",
    "prettier": "^3.5.3"
  }
}
