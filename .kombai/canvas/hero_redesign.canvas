    "var_eec9d746c12a": {
      "type": "variant",
      "label": "Midnight Aurora Hero",
      "parentId": null,
      "themeId": null,
      "rect": {
        "x": 9240,
        "y": 0,
        "w": 1440,
        "h": 1200
