      "html": "\n<div class=\"w-full bg-[#F9F8F6] font-['Inter'] selection:bg-[#D4AF37]/30 selection:text-[#0A1128] overflow-hidden min-h-[900px]\" data-kid=\"0\">\n  <style data-kid=\"1\">\n    @import url('https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,700;1,400&family=Inter:wght@400;500;600;700&display=swap');\n    @import url('https://cdn.jsdelivr.net/npm/@tabler/icons-webfont/tabler-icons.min.css');\n\n    .font-serif { font-family: 'Playfair Display', serif; }\n    .font-sans { font-family: 'Inter', sans-serif; }\n\n    .diagonal-split {\n      clip-path: polygon(0 0, 100% 0, 85% 100%, 0% 100%);\n    }\n\n    .diagonal-border {\n      position: absolute;\n      top: 0;\n      right: 0;\n      width: 100%;\n      height: 100%;\n      pointer-events: none;\n      z-index: 15;\n    }\n\n    .diagonal-border svg {\n      width: 100%;\n      height: 100%;\n      position: absolute;\n      top: 0;\n      right: 0;\n    }\n\n    .reveal-item {\n      opacity: 0;\n      transform: translateY(20px);\n      animation: reveal-up 1.2s cubic-bezier(0.19, 1, 0.22, 1) forwards;\n    }\n\n    @keyframes reveal-up {\n      to {\n        opacity: 1;\n        transform: translateY(0);\n      }\n    }\n\n    .ticker-animation {\n      display: flex;\n      width: fit-content;\n      animation: ticker-loop 30s linear infinite;\n    }\n\n    @keyframes ticker-loop {\n      0% { transform: translateX(0); }\n      100% { transform: translateX(-50%); }\n    }\n\n    .input-ivy {\n      background: rgba(255, 255, 255, 0.8);\n      border: 1px solid rgba(10, 17, 40, 0.08);\n      transition: all 0.3s cubic-bezier(0.19, 1, 0.22, 1);\n    }\n\n    .input-ivy:focus {\n      border-color: #D4AF37;\n      box-shadow: 0 0 0 1px #D4AF37;\n      background: white;\n      outline: none;\n    }\n\n    .glass-login-card {\n      background: rgba(255, 255, 255, 0.65);\n      backdrop-filter: blur(24px);\n      -webkit-backdrop-filter: blur(24px);\n      border: 1px solid rgba(255, 255, 255, 0.4);\n      box-shadow: 0 40px 100px rgba(10, 17, 40, 0.1);\n    }\n\n    .dot-grid {\n      background-image: radial-gradient(rgba(212, 175, 55, 0.12) 1px, transparent 1px);\n      background-size: 30px 30px;\n    }\n  </style>\n\n  <main class=\"relative w-full h-[900px] flex overflow-hidden\" data-kid=\"2\">\n    \n    \n    <section class=\"relative w-[45%] bg-[#0A1128] diagonal-split z-10 flex flex-col justify-center px-24 h-full\" data-kid=\"3\">\n      <div class=\"diagonal-border\" data-kid=\"4\">\n        <svg viewBox=\"0 0 100 100\" preserveAspectRatio=\"none\" data-kid=\"5\">\n          <line x1=\"100\" y1=\"0\" x2=\"85\" y2=\"100\" stroke=\"#D4AF37\" stroke-width=\"0.1\" stroke-opacity=\"0.4\" data-kid=\"6\"></line>\n        </svg>\n      </div>\n      \n      <div class=\"absolute inset-0 dot-grid opacity-30 pointer-events-none\" data-kid=\"7\"></div>\n      <div class=\"absolute top-[-10%] left-[-10%] w-[500px] h-[500px] rounded-full bg-[#D4AF37]/5 blur-[120px] pointer-events-none\" data-kid=\"8\"></div>\n      \n      <div class=\"relative max-w-lg\" data-kid=\"9\">\n        <div class=\"reveal-item mb-8\" style=\"animation-delay: 100ms;\" data-kid=\"10\">\n          <div class=\"h-[2px] w-16 bg-[#D4AF37]\" data-kid=\"11\"></div>\n        </div>\n\n        <h1 class=\"reveal-item font-serif text-7xl text-white leading-[1.1] mb-8\" style=\"animation-delay: 200ms;\" data-kid=\"12\">\n          Welcome back to <br data-kid=\"13\">\n          <span class=\"italic font-normal text-[#D4AF37]\" data-kid=\"14\">the Academy</span>\n        </h1>\n\n        <p class=\"reveal-item text-white/50 text-xl font-light leading-relaxed mb-12\" style=\"animation-delay: 300ms;\" data-kid=\"15\">\n          Enter the secure gateway of EduTechEx. Continue your journey in developing world-class curriculum and academic intelligence.\n        </p>\n\n        <div class=\"reveal-item flex items-center gap-6\" style=\"animation-delay: 400ms;\" data-kid=\"16\">\n          <div class=\"flex -space-x-3\" data-kid=\"17\">\n            <img src=\"https://i.pravatar.cc/100?u=dean1\" class=\"w-10 h-10 rounded-full border-2 border-[#0A1128]\" alt=\"Faculty\" decoding=\"async\" loading=\"lazy\" data-kid=\"18\">\n            <img src=\"https://i.pravatar.cc/100?u=tech2\" class=\"w-10 h-10 rounded-full border-2 border-[#0A1128]\" alt=\"Researcher\" decoding=\"async\" loading=\"lazy\" data-kid=\"19\">\n            <img src=\"https://i.pravatar.cc/100?u=admin3\" class=\"w-10 h-10 rounded-full border-2 border-[#0A1128]\" alt=\"Admin\" decoding=\"async\" loading=\"lazy\" data-kid=\"20\">\n          </div>\n          <span class=\"text-white/40 text-xs font-bold tracking-widest uppercase\" data-kid=\"21\">Verified Institution Access</span>\n        </div>\n      </div>\n\n      \n      <div class=\"absolute bottom-12 left-24 reveal-item\" style=\"animation-delay: 500ms;\" data-kid=\"22\">\n        <p class=\"text-white/20 text-[10px] tracking-[0.3em] font-bold uppercase\" data-kid=\"23\">System v2.4.0 • Secured Encryption</p>\n      </div>\n    </section>\n\n    \n    <section class=\"relative flex-1 bg-[#F9F8F6] flex flex-col items-center h-full overflow-hidden\" data-kid=\"24\">\n      \n      <div class=\"absolute inset-0 opacity-[0.03] pointer-events-none\" style=\"background-image: url('https://www.transparenttextures.com/patterns/natural-paper.png');\" data-kid=\"25\"></div>\n\n      \n      <div class=\"w-full max-w-lg mt-16 px-8 z-30 reveal-item\" style=\"animation-delay: 100ms;\" data-kid=\"26\">\n        <div class=\"flex items-center gap-4\" data-kid=\"27\">\n          <div class=\"w-14 h-14 bg-[#D4AF37] rounded-sm flex items-center justify-center shadow-xl shadow-[#D4AF37]/20\" data-kid=\"28\">\n            <span class=\"text-[#0A1128] font-black text-xl\" data-kid=\"29\">EX</span>\n          </div>\n          <div data-kid=\"30\">\n            <span class=\"font-serif text-3xl font-bold tracking-tight text-[#0A1128]\" data-kid=\"31\">EduTechEx</span>\n            <span class=\"block text-[9px] font-black text-[#0A1128]/50 tracking-[0.4em] uppercase mt-0.5\" data-kid=\"32\">Institutional Portal</span>\n          </div>\n        </div>\n      </div>\n\n      \n      <div class=\"w-full max-w-lg mt-12 px-8 relative z-20 reveal-item\" style=\"animation-delay: 200ms;\" data-kid=\"33\">\n        <div class=\"glass-login-card p-10 rounded-2xl\" data-kid=\"34\">\n          \n          <div class=\"mb-8\" data-kid=\"35\">\n            <h2 class=\"font-serif text-4xl text-[#0A1128] mb-2\" data-kid=\"36\">Sign In</h2>\n            <p class=\"text-[#0A1128]/50 text-sm\" data-kid=\"37\">Please authenticate with your institutional credentials.</p>\n          </div>\n\n          \n          <form class=\"space-y-6\" data-kid=\"38\">\n          \n          <div class=\"space-y-2.5\" data-kid=\"39\">\n            <label class=\"text-[11px] font-black uppercase tracking-[0.2em] text-[#0A1128]/80 ml-1\" data-kid=\"40\">Institutional Email</label>\n            <div class=\"relative group\" data-kid=\"41\">\n              <i class=\"ti ti-mail absolute left-4 top-1/2 -translate-y-1/2 text-[#0A1128]/30 group-focus-within:text-[#D4AF37] transition-colors\" data-kid=\"42\"></i>\n              <input type=\"email\" placeholder=\"email@institution.edu\" class=\"input-ivy w-full pl-12 pr-4 py-4 text-sm text-[#0A1128] font-medium placeholder:text-[#0A1128]/20\" required data-kid=\"43\">\n            </div>\n          </div>\n\n          \n          <div class=\"space-y-2.5\" data-kid=\"44\">\n            <div class=\"flex justify-between items-center ml-1\" data-kid=\"45\">\n              <label class=\"text-[11px] font-black uppercase tracking-[0.2em] text-[#0A1128]/80\" data-kid=\"46\">Security Key</label>\n              <button type=\"button\" class=\"text-[10px] font-bold text-[#D4AF37] hover:underline transition-all\" data-kid=\"47\">Forgot Key?</button>\n            </div>\n            <div class=\"relative group\" data-kid=\"48\">\n              <i class=\"ti ti-lock absolute left-4 top-1/2 -translate-y-1/2 text-[#0A1128]/30 group-focus-within:text-[#D4AF37] transition-colors\" data-kid=\"49\"></i>\n              <input type=\"password\" placeholder=\"••••••••••••\" class=\"input-ivy w-full pl-12 pr-12 py-4 text-sm text-[#0A1128] font-medium placeholder:text-[#0A1128]/20\" required data-kid=\"50\">\n              <button type=\"button\" class=\"absolute right-4 top-1/2 -translate-y-1/2 text-[#0A1128]/20 hover:text-[#0A1128]/60 transition-colors\" data-kid=\"51\">\n                <i class=\"ti ti-eye text-lg\" data-kid=\"52\"></i>\n              </button>\n            </div>\n          </div>\n\n            \n            <div class=\"pt-4\" data-kid=\"53\">\n              <button class=\"group relative w-full bg-[#D4AF37] text-[#0A1128] py-5 font-black uppercase tracking-[0.3em] text-[11px] overflow-hidden transition-all hover:bg-[#c4a132] active:scale-[0.98]\" data-kid=\"54\">\n                <span class=\"relative z-10\" data-kid=\"55\">Enter System</span>\n                <div class=\"absolute inset-0 bg-white/10 -translate-x-full group-hover:translate-x-0 transition-transform duration-500\" data-kid=\"56\"></div>\n              </button>\n            </div>\n\n            \n            <div class=\"text-center pt-8\" data-kid=\"57\">\n              <p class=\"text-xs text-[#0A1128]/40\" data-kid=\"58\">\n                New to the institution? \n                <button type=\"button\" class=\"text-[#0A1128] font-bold hover:text-[#D4AF37] underline underline-offset-4 transition-colors ml-1\" data-kid=\"59\">Request Access</button>\n              </p>\n            </div>\n          </form>\n        </div>\n      </div>\n\n      \n      <div class=\"absolute bottom-0 left-0 w-full py-10 bg-white/40 backdrop-blur-xl border-t border-[#0A1128]/5 overflow-hidden\" data-kid=\"60\">\n        <div class=\"flex flex-col items-center mb-6 opacity-40\" data-kid=\"61\">\n          <span class=\"text-[#0A1128] text-[10px] font-black tracking-[0.5em] uppercase\" data-kid=\"62\">Trusted Academic Partners</span>\n        </div>\n        \n        <div class=\"relative w-full flex overflow-hidden\" data-kid=\"63\">\n          <div class=\"ticker-animation items-center gap-32 px-16\" data-kid=\"64\">\n            \n            <div class=\"flex items-center gap-4 text-[#D4AF37]/35\" data-kid=\"65\">\n              <i class=\"ti ti-building-arch text-xl\" data-kid=\"66\"></i>\n              <span class=\"font-serif text-lg font-bold tracking-tight\" data-kid=\"67\">OXFORD</span>\n            </div>\n            <div class=\"flex items-center gap-4 text-[#D4AF37]/40\" data-kid=\"68\">\n              <i class=\"ti ti-award text-xl\" data-kid=\"69\"></i>\n              <span class=\"font-serif text-lg font-bold tracking-tight\" data-kid=\"70\">STAMFORD</span>\n            </div>\n            <div class=\"flex items-center gap-4 text-[#D4AF37]/40\" data-kid=\"71\">\n              <i class=\"ti ti-book text-xl\" data-kid=\"72\"></i>\n              <span class=\"font-serif text-lg font-bold tracking-tight\" data-kid=\"73\">HARVARD</span>\n            </div>\n            <div class=\"flex items-center gap-4 text-[#D4AF37]/40\" data-kid=\"74\">\n              <i class=\"ti ti-certificate text-xl\" data-kid=\"75\"></i>\n              <span class=\"font-serif text-lg font-bold tracking-tight\" data-kid=\"76\">PRINCETON</span>\n            </div>\n            <div class=\"flex items-center gap-4 text-[#D4AF37]/40\" data-kid=\"77\">\n              <i class=\"ti ti-library text-xl\" data-kid=\"78\"></i>\n              <span class=\"font-serif text-lg font-bold tracking-tight\" data-kid=\"79\">CAMBRIDGE</span>\n            </div>\n            \n            <div class=\"flex items-center gap-4 text-[#D4AF37]/40\" data-kid=\"80\">\n              <i class=\"ti ti-building-arch text-xl\" data-kid=\"81\"></i>\n              <span class=\"font-serif text-lg font-bold tracking-tight\" data-kid=\"82\">OXFORD</span>\n            </div>\n            <div class=\"flex items-center gap-4 text-[#D4AF37]/40\" data-kid=\"83\">\n              <i class=\"ti ti-award text-xl\" data-kid=\"84\"></i>\n              <span class=\"font-serif text-lg font-bold tracking-tight\" data-kid=\"85\">STAMFORD</span>\n            </div>\n            <div class=\"flex items-center gap-4 text-[#D4AF37]/40\" data-kid=\"86\">\n              <i class=\"ti ti-book text-xl\" data-kid=\"87\"></i>\n              <span class=\"font-serif text-lg font-bold tracking-tight\" data-kid=\"88\">HARVARD</span>\n            </div>\n            <div class=\"flex items-center gap-4 text-[#D4AF37]/40\" data-kid=\"89\">\n              <i class=\"ti ti-certificate text-xl\" data-kid=\"90\"></i>\n              <span class=\"font-serif text-lg font-bold tracking-tight\" data-kid=\"91\">PRINCETON</span>\n            </div>\n            <div class=\"flex items-center gap-4 text-[#D4AF37]/40\" data-kid=\"92\">\n              <i class=\"ti ti-library text-xl\" data-kid=\"93\"></i>\n              <span class=\"font-serif text-lg font-bold tracking-tight\" data-kid=\"94\">CAMBRIDGE</span>\n            </div>\n          </div>\n        </div>\n      </div>\n    </section>\n\n  </main>\n</div>\n",
