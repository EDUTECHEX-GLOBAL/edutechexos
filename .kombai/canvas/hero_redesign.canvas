      <div class=\"flex-1 h-2 bg-[#1B3B36]/10 rounded-full\" data-kid=\"64\"></div>\n                    </div>\n                  </div>\n                </div>\n              </div>\n            </div>\n          </div>\n        </div>\n      </div>\n\n      </div>\n\n      \n      <div class=\"absolute inset-0 pointer-events-none z-50\" data-kid=\"65\">\n        \n        <div class=\"animate-float absolute top-[2%] left-[-12%] md:left-[-8%]\" data-kid=\"66\">\n          <div class=\"bg-[#D97757] text-[#F2EFE9] font-mono px-8 py-4 rounded-full shadow-[0_20px_40px_rgba(217,119,87,0.4)] flex items-center gap-3 border border-white/20 pointer-events-auto cursor-default hover:scale-110 transition-transform\" data-kid=\"67\">\n            <div class=\"w-2.5 h-2.5 rounded-full bg-white/90 animate-pulse\" data-kid=\"68\"></div>\n            <span class=\"text-sm font-bold tracking-tight uppercase\" data-kid=\"69\">Channels</span>\n          </div>\n        </div>\n        \n        <div class=\"animate-float absolute top-[25%] right-[-12%] md:right-[-10%]\" style=\"animation-duration: 9s;\" data-kid=\"70\">\n          <div class=\"bg-[#D97757] text-[#F2EFE9] font-mono px-8 py-4 rounded-full shadow-[0_20px_40px_rgba(217,119,87,0.4)] flex items-center gap-4 border border-white/20 pointer-events-auto cursor-default hover:scale-110 transition-transform\" data-kid=\"71\">\n            <i class=\"ti ti-cpu text-xl\" data-kid=\"72\"></i>\n            <span class=\"text-sm font-bold tracking-tight uppercase\" data-kid=\"73\">Embedded AI</span>\n          </div>\n        </div>\n        \n        <div class=\"animate-float absolute bottom-[5%] left-[-15%] md:left-[-12%]\" style=\"animation-duration: 7s;\" data-kid=\"74\">\n          <div class=\"bg-[#D97757] text-[#F2EFE9] font-mono px-8 py-4 rounded-full shadow-[0_20px_40px_rgba(217,119,87,0.4)] flex items-center gap-4 border border-white/20 pointer-events-auto cursor-default hover:scale-110 transition-transform\" data-kid=\"75\">\n            <i class=\"ti ti-list-check text-xl\" data-kid=\"76\"></i>\n            <span class=\"text-sm font-bold tracking-tight uppercase\" data-kid=\"77\">Auto-Tasks</span>\n          </div>\n        </div>\n        \n        <div class=\"animate-float absolute bottom-[35%] right-[-15%] md:right-[-12%]\" style=\"animation-duration: 10s;\" data-kid=\"78\">\n          <div class=\"bg-[#D97757] text-[#F2EFE9] font-mono px-8 py-4 rounded-full shadow-[0_20px_40px_rgba(217,119,87,0.4)] flex items-center gap-4 border border-white/20 pointer-events-auto cursor-default\" data-kid=\"79\">\n            <i class=\"ti ti-inbox text-xl\" data-kid=\"80\"></i>\n            <span class=\"text-sm font-bold tracking-tight uppercase\" data-kid=\"81\">Morning Digests</span>\n          </div>\n        </div>\n      </div>\n    </div>\n\n    \n    <div class=\"mt-16 z-40\" data-kid=\"82\">\n      <button class=\"group bg-[#1B3B36] text-[#F2EFE9] font-cabinet text-xl px-16 py-6 rounded-full hover:bg-[#D97757] transition-all duration-500 shadow-2xl hover:scale-105 active:scale-95 flex items-center gap-4\" data-kid=\"83\">\n        REIMAGINE YOUR WORKFLOW\n        <i class=\"ti ti-arrow-right text-2xl group-hover:translate-x-2 transition-transform\" data-kid=\"84\"></i>\n      </button>\n    </div>\n\n    \n    <div class=\"absolute left-10 top-1/2 -translate-y-1/2 hidden xl:block opacity-20 pointer-events-none\" data-kid=\"85\">\n      <div class=\"w-px h-96 dash-line\" data-kid=\"86\"></div>\n    </div>\n    <div class=\"absolute right-10 top-1/2 -translate-y-1/2 hidden xl:block opacity-20 pointer-events-none\" data-kid=\"87\">\n      <div class=\"w-px h-96 dash-line\" data-kid=\"88\"></div>\n    </div>\n  </section>\n\n  \n  <section class=\"bg-white/30 backdrop-blur-sm border-t border-[#1B3B36]/5 py-24 px-8\" data-kid=\"89\">\n    <div class=\"max-w-7xl mx-auto grid grid-cols-1 md:grid-cols-3 gap-16 lg:gap-24\" data-kid=\"90\">\n      \n      \n      <div class=\"flex flex-col items-center text-center group\" data-kid=\"91\">\n        <div class=\"w-20 h-20 rounded-full bg-[#1B3B36] flex items-center justify-center text-[#F2EFE9] mb-8 transition-all duration-500 group-hover:rotate-[360deg] group-hover:bg-[#D97757] shadow-xl ring-4 ring-white\" data-kid=\"92\">\n          <i class=\"ti ti-cpu text-4xl leading-none\" data-kid=\"93\"></i>\n        </div>\n        <h3 class=\"font-mono text-lg font-bold text-[#1B3B36] mb-4 tracking-tighter uppercase\" data-kid=\"94\">Intelligent Core</h3>\n        <p class=\"font-mono text-sm text-[#1B3B36]/60 leading-relaxed max-w-xs\" data-kid=\"95\">\n          Native AI models contextually embedded within your workspace for seamless educational content generation.\n        </p>\n      </div>\n\n      \n      <div class=\"flex flex-col items-center text-center group\" data-kid=\"96\">\n        <div class=\"w-20 h-20 rounded-full bg-[#1B3B36] flex items-center justify-center text-[#F2EFE9] mb-8 transition-all duration-500 group-hover:rotate-[360deg] group-hover:bg-[#D97757] shadow-xl ring-4 ring-white\" data-kid=\"97\">\n          <i class=\"ti ti-list-check text-4xl leading-none\" data-kid=\"98\"></i>\n        </div>\n        <h3 class=\"font-mono text-lg font-bold text-[#1B3B36] mb-4 tracking-tighter uppercase\" data-kid=\"99\">Fluid Actions</h3>\n        <p class=\"font-mono text-sm text-[#1B3B36]/60 leading-relaxed max-w-xs\" data-kid=\"100\">\n          Our engine automatically identifies action items from your channels, so nothing ever falls through the cracks.\n        </p>\n      </div>\n\n      \n      <div class=\"flex flex-col items-center text-center group\" data-kid=\"101\">\n        <div class=\"w-20 h-20 rounded-full bg-[#1B3B36] flex items-center justify-center text-[#F2EFE9] mb-8 transition-all duration-500 group-hover:rotate-[360deg] group-hover:bg-[#D97757] shadow-xl ring-4 ring-white\" data-kid=\"102\">\n          <i class=\"ti ti-inbox text-4xl leading-none\" data-kid=\"103\"></i>\n        </div>\n        <h3 class=\"font-mono text-lg font-bold text-[#1B3B36] mb-4 tracking-tighter uppercase\" data-kid=\"104\">Cognitive Sync</h3>\n        <p class=\"font-mono text-sm text-[#1B3B36]/60 leading-relaxed max-w-xs\" data-kid=\"105\">\n          Wake up to a curated summary of key discussions and deadlines, tailored for tech-focused educational leaders.\n        </p>\n      </div>\n\n    </div>\n  </section>\n\n  \n  <footer class=\"py-12 border-t border-[#1B3B36]/5 px-12 flex flex-col md:flex-row items-center justify-between gap-6 opacity-40\" data-kid=\"106\">\n    <p class=\"font-mono text-[10px] font-bold tracking-[0.2em] text-[#1B3B36] uppercase\" data-kid=\"107\">© 2024 EDUTECHEX SYSTEMS. ALL RIGHTS RESERVED.</p>\n    <div class=\"flex gap-8 font-mono text-[10px] font-bold tracking-[0.2em] text-[#1B3B36] uppercase\" data-kid=\"108\">\n      <a href=\"#\" class=\"hover:text-[#D97757]\" data-kid=\"109\">Privacy</a>\n      <a href=\"#\" class=\"hover:text-[#D97757]\" data-kid=\"110\">Terms</a>\n      <a href=\"#\" class=\"hover:text-[#D97757]\" data-kid=\"111\">Contact</a>\n    </div>\n  </footer>\n\n</div>\n",
