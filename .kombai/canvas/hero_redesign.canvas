n>\n                <i class=\"ti ti-circle-check text-emerald-500/50\" data-kid=\"191\"></i>\n              </div>\n              \n              <div class=\"bg-[#0A1128]/[0.02] p-6 rounded-sm border border-[#0A1128]/5 opacity-60 hover:opacity-100 transition-opacity\" data-kid=\"192\">\n                <div class=\"flex justify-between items-start mb-5\" data-kid=\"193\">\n                  <span class=\"bg-emerald-500/10 text-emerald-600 text-[9px] font-black px-2 py-0.5 rounded-xs uppercase tracking-widest\" data-kid=\"194\">Archived</span>\n                  <i class=\"ti ti-check text-emerald-500\" data-kid=\"195\"></i>\n                </div>\n                <h4 class=\"font-bold text-[#0A1128] text-sm leading-snug mb-4 line-through decoration-[#0A1128]/20\" data-kid=\"196\">Semester II Curriculum Validation Framework</h4>\n              </div>\n\n              <div class=\"bg-[#0A1128]/[0.02] p-6 rounded-sm border border-[#0A1128]/5 opacity-60\" data-kid=\"197\">\n                <h4 class=\"font-bold text-[#0A1128] text-sm leading-snug line-through decoration-[#0A1128]/20 italic\" data-kid=\"198\">Faculty Onboarding v4.2</h4>\n              </div>\n            </div>\n          </div>\n        </div>\n      </div>\n\n      \n      <footer class=\"mt-24 pt-16 border-t border-[#0A1128]/5 overflow-hidden reveal-up\" style=\"animation-delay: 600ms;\" data-kid=\"199\">\n        <div class=\"flex items-center justify-center gap-8 mb-12\" data-kid=\"200\">\n          <div class=\"h-px w-20 bg-gradient-to-r from-transparent to-[#D4AF37]\" data-kid=\"201\"></div>\n          <span class=\"text-[#D4AF37] text-[10px] font-bold tracking-[0.5em] uppercase text-center\" data-kid=\"202\">Standardizing Academic Excellence Globally</span>\n          <div class=\"h-px w-20 bg-gradient-to-l from-transparent to-[#D4AF37]\" data-kid=\"203\"></div>\n        </div>\n\n        <div class=\"relative w-full overflow-hidden py-4\" data-kid=\"204\">\n          \n          <div class=\