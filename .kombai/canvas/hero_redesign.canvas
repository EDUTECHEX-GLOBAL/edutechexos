      "html": "<div class=\"flex bg-[#F9F8F6] min-h-[900px] font-['Inter'] selection:bg-[#D4AF37]/30 selection:text-[#0A1128]\" data-kid=\"0\">\n  <style data-kid=\"1\">\n    @import url('https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,700;1,400&family=Inter:wght@400;500;600;700;900&display=swap');\n    @import url('https://cdn.jsdelivr.net/npm/@tabler/icons-webfont/tabler-icons.min.css');\n\n    .font-serif { font-family: 'Playfair Display', serif; }\n    .font-sans { font-family: 'Inter', sans-serif; }\n\n    .glass-card {\n      background: rgba(255, 255, 255, 0.65);\n      backdrop-filter: blur(18px);\n      -webkit-backdrop-filter: blur(18px);\n      border: 1px solid rgba(255, 255, 255, 0.4);\n      box-shadow: 0 20px 50px rgba(10, 17, 40, 0.08);\n    }\n\n    .diagonal-accent {\n      clip-path: polygon(0 0, 100% 0, 100% 100%, 15% 100%);\n    }\n\n    .diagonal-header {\n      clip-path: polygon(0 0, 100% 0, 92% 100%, 0% 100%);\n    }\n\n    .reveal-up {\n      opacity: 0;\n      transform: translateY(20px);\n      animation: reveal-up-anim 0.8s cubic-bezier(0.19, 1, 0.22, 1) forwards;\n    }\n\n    @keyframes reveal-up-anim {\n      to {\n        opacity: 1;\n        transform: translateY(0);\n      }\n    }\n\n    .float-card {\n      animation: float-anim 6s ease-in-out infinite;\n    }\n\n    @keyframes float-anim {\n      0%, 100% { transform: translateY(0); }\n      50% { transform: translateY(-10px); }\n    }\n\n    .ticker-track {\n      display: flex;\n      width: fit-content;\n      animation: ticker-anim 40s linear infinite;\n    }\n\n    @keyframes ticker-anim {\n      0% { transform: translateX(0); }\n      100% { transform: translateX(-50%); }\n    }\n\n    .gold-glow {\n      box-shadow: 0 0 20px rgba(212, 175, 55, 0.2);\n    }\n\n    .no-scrollbar::-webkit-scrollbar {\n      display: none;\n    }\n    .no-scrollbar {\n      -ms-overflow-style: none;\n      scrollbar-width: none;\n    }\n\n    .ai-wave-overlay {\n      background: radial-gradient(circle at top right, rgba(212, 175, 55, 0.15), transparent 60%),\n                  linear-gradient(135deg, rgba(10, 17, 40, 0.95), rgba(10, 17, 40, 0.7));\n    }\n  </style>\n\n  \n  <aside class=\"w-20 bg-[#0A1128] flex flex-col items-center py-10 shrink-0 relative z-50 min-h-screen\" data-kid=\"2\">\n    \n    <div class=\"absolute inset-0 opacity-[0.03] pointer-events-none\" style=\"background-image: radial-gradient(#D4AF37 1px, transparent 1px); background-size: 20px 20px;\" data-kid=\"3\"></div>\n\n    <div class=\"w-10 h-10 bg-[#D4AF37] rounded-sm flex items-center justify-center gold-glow mb-12 relative z-10 transition-transform hover:scale-105 active:scale-95 cursor-pointer\" data-kid=\"4\">\n      <span class=\"text-[#0A1128] font-black text-xs tracking-tighter\" data-kid=\"5\">OS</span>\n    </div>\n\n    <nav class=\"flex flex-col gap-10 relative z-10\" data-kid=\"6\">\n      <div class=\"group relative flex flex-col items-center cursor-pointer\" data-kid=\"7\">\n        <div class=\"absolute left-[-20px] top-1/2 -translate-y-1/2 w-1.5 h-6 bg-[#D4AF37] rounded-r-full transition-all opacity-0 group-[.active]:opacity-100\" data-kid=\"8\"></div>\n        <i class=\"ti ti-message-2 text-[26px] text-white/50 group-hover:text-[#D4AF37] transition-all\" data-kid=\"9\"></i>\n        <span class=\"text-[9px] font-black text-white/30 mt-1 uppercase tracking-widest opacity-0 group-hover:opacity-100 transition-opacity\" data-kid=\"10\">Chat</span>\n      </div>\n\n      <div class=\"group relative active flex flex-col items-center cursor-pointer\" data-kid=\"11\">\n        <div class=\"absolute left-[-20px] top-1/2 -translate-y-1/2 w-1.5 h-6 bg-[#D4AF37] rounded-r-full transition-all opacity-100\" data-kid=\"12\"></div>\n        <i class=\"ti ti-layout-kanban text-[26px] text-[#D4AF37] transition-all\" data-kid=\"13\"></i>\n        <span class=\"text-[9px] font-black text-[#D4AF37] mt-1 uppercase tracking-widest\" data-kid=\"14\">Task