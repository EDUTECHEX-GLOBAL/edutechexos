      "html": "\n<style data-kid=\"0\">\n  @import url('https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;1,400&family=Inter:wght@300;400;700;900&family=JetBrains+Mono:wght@400;700&display=swap');\n\n  :root {\n    --color-bg: #191E2F;\n    --color-primary: #3E4A89;\n    --color-primary-light: #9BA6D3;\n    --color-accent: #FAF8F5;\n  }\n\n  .font-sans { font-family: 'Inter', sans-serif; }\n  .font-serif { font-family: 'Playfair Display', serif; }\n  .font-mono { font-family: 'JetBrains Mono', monospace; }\n\n  .architectural-grid {\n    background-image: \n      linear-gradient(to right, rgba(255,255,255,0.03) 1px, transparent 1px),\n      linear-gradient(to bottom, rgba(255,255,255,0.03) 1px, transparent 1px);\n    background-size: 80px 80px;\n  }\n  \n  .scanning-line {\n    height: 1px;\n    background: linear-gradient(90deg, transparent, rgba(155, 166, 211, 0.2), transparent);\n    width: 100%;\n    position: absolute;\n    animation: scan 8s linear infinite;\n  }\n\n  @keyframes scan {\n    0% { top: 0%; }\n    100% { top: 100%; }\n  }\n\n  .writing-vertical {\n    writing-mode: vertical-rl;\n  }\n\n  @keyframes float-slow {\n    0%, 100% { transform: translateY(0px) rotate(0deg); }\n    50% { transform: translateY(-40px) rotate(2deg); }\n  }\n  .animate-float-slow {\n    animation: float-slow 12s ease-in-out infinite;\n  }\n  \n  .mask-vignette {\n    mask-image: radial-gradient(circle at center, black 30%, transparent 100%);\n  }\n</style>\n\n<div class=\"bg-[var(--color-bg)] text-[var(--color-accent)] min-h-[900px] relative overflow-hidden font-sans flex\" data-kid=\"1\">\n  \n  \n  <div class=\"absolute inset-0 architectural-grid pointer-events-none z-0\" data-kid=\"2\"></div>\n  \n  \n  <aside class=\"w-[288px] h-full border-r border-white/10 flex flex-col justify-between py-12 px-0 relative z-40 bg-[var(--color-bg)]/95 backdrop-blur-sm\" data-kid=\"3\">\n    \n    \n    <div class=\"flex flex-col items-center gap-16\" data-kid=\"4\">\n      <div class=\"w-16 h-16 border border-white/20 flex items-center justify-center font-black text-2xl relative group hover:bg-white/5 transition-colors cursor-crosshair\" data-kid=\"5\">\n        EX\n        <div class=\"absolute -top-1 -right-1 w-2.5 h-2.5 bg-[var(--color-primary-light)] shadow-[0_0_8px_var(--color-primary-light)]\" data-kid=\"13\"></div>\n      </div>\n      \n      <div class=\"h-64 flex items-center\" data-kid=\"6\">\n        <span class=\"text-[10px] font-mono tracking-[0.8em] uppercase opacity-40 writing-vertical rotate-180\" data-kid=\"7\">\n          Architectural Premium v4.02 // REV_B\n        </span>\n      </div>\n    </div>\n\n    \n    <div class=\"flex flex-col items-center gap-10\" data-kid=\"8\">\n      <div class=\"h-24 w-[1px] bg-white/10\" data-kid=\"11\"></div>\n      <div class=\"flex flex-col items-center gap-16 opacity-30\" data-kid=\"9\">\n        <div class=\"flex flex-col items-center gap-4\" data-kid=\"100\">\n          <span class=\"text-[9px] font-mono tracking-[0.4em] writing-vertical rotate-180\" data-kid=\"10\">40.7128° N</span>\n          <span class=\"text-[9px] font-mono tracking-[0.4em] writing-vertical rotate-180\" data-kid=\"12\">74.0060° W</span>\n        </div>\n        <div class=\"writing-vertical rotate-180 text-[8px] font-mono tracking-[0.6em] uppercase\" data-kid=\"101\">\n          BLUEPRINT_STABLE\n        </div>\n      </div>\n      <div class=\"h-24 w-[1px] bg-white/10\" data-kid=\"102\"></div>\n    </div>\n\n    \n    <div class=\"flex flex-col items-center gap-12 pb-12\" data-kid=\"14\">\n      <div class=\"relative flex flex-col items-center group\" data-kid=\"15\">\n        <div class=\"w-2 h-2 rounded-full bg-green-500 shadow-[0_0_15px_rgba(34,197,94,0.8)] animate-pulse\" data-kid=\"17\"></div>\n        <span class=\"text-[9px] font-mono uppercase tracking-[0.4em] opacity-30 group-hover:opacity-100 transition-opacity writing-vertical rotate-180 mt-6\" data-kid=\"18\">SYSTEM_STABLE</span>\n      </div>\n      <div class=\"relative flex flex-col items-center group\" data-kid=\"19\">\n        <div class=\"w-2 h-2 rounded-full bg-yellow-500 shadow-[0_0_10px_rgba(234,179,8,0.4)]\" data-kid=\"21\"></div>\n        <span class=\"text-[9px] font-mono uppercase tracking-[0.4em] opacity-30 group-hover:opacity-100 transition-opacity writing-vertical rotate-180 mt-6\" data-kid=\"22\">ENCRYPT_ACTIVE</span>\n      </div>\n    </div>\n  </aside>\n\n  \n  <main class=\"flex-1 flex flex-col relative z-10\" data-kid=\"23\">\n    \n    \n    <div class=\"absolute inset-0 z-0 opacity-15 pointer-events-none\" data-kid=\"103\">\n      <div class=\"scanning-line z-10\" data-kid=\"16\"></div>\n      <img \n        src=\"https://images.unsplash.com/photo-1561233835-f937539b95b9?auto=format&w=1600&q=80&fit=crop\" \n        alt=\"\" \n        class=\"w-full h-full object-cover grayscale contrast-125 brightness-75\"\n        decoding=\"async\" \n        loading=\"lazy\"\n        data-kid=\"104\"\n      >\n      <div class=\"absolute inset-0 bg-gradient-to-r from-[var(--color-bg)] via-transparent to-[var(--color-bg)]\" data-kid=\"20\"></div>\n    </div>\n\n    \n    <div class=\"flex-1 flex\" data-kid=\"24\">\n      \n      \n      <div class=\"flex-1 flex flex-col py-20 pl-24 pr-12 relative z-20\" data-kid=\"25\">\n        \n        \n        <div class=\"flex items-center gap-8 mb-20 opacity-20 text-[10px] font-mono tracking-[0.8em] uppercase\" data-kid=\"26\">\n          <span data-kid=\"85\">SECTOR_GRID_X_72</span>\n          <div class=\"w-12 h-[1px] bg-white\" data-kid=\"86\"></div>\n          <span data-kid=\"87\">MAINFRAME_V4</span>\n        </div>\n\n        \n        <div class=\"flex-1 flex flex-col justify-center max-w-4xl\" data-kid=\"27\">\n          <div class=\"relative mb-16\" data-kid=\"28\">\n            <span class=\"absolute -top-10 left-0 text-[11px] font-mono opacity-20 tracking-[1.2em]\" data-kid=\"29\">CORE_INFRASTRUCTURE</span>\n            <h1 class=\"text-[clamp(4rem,10vw,8.5rem)] font-black leading-[0.85] tracking-tighter\" data-kid=\"30\">\n              CORE<br data-kid=\"31\">\n              SYSTEMS<span class=\"text-[var(--color-primary-light)]\" data-kid=\"32\">.</span>\n            </h1>\n          </div>\n\n          <div class=\"border-l-2 border-[var(--color-primary-light)]/20 pl-12 py-8 space-y-12\" data-kid=\"33\">\n            <p class=\"font-serif italic text-[2.8rem] font-light text-[var(--color-primary-light)] leading-[1.1] opacity-90 tracking-tight\" data-kid=\"34\">\n              Engineered for total precision. Built for institutional scale. The foundational architecture for excellence.\n            </p>\n            \n            <div class=\"flex items-center gap-12 pt-8\" data-kid=\"35\">\n              <button class=\"group relative px-16 py-7 bg-transparent border border-[var(--color-primary-light)]/40 text-white font-bold tracking-[0.5em] uppercase text-xs overflow-hidden transition-all hover:bg-[var(--color-primary-light)] hover:text-[var(--color-bg)] hover:border-transparent\" data-kid=\"36\">\n                <span class=\"relative z-10\" data-kid=\"37\">Deploy Module</span>\n                <div class=\"absolute top-0 right-0 w-3 h-3 border-r border-t border-white/40\" data-kid=\"38\"></div>\n                <div class=\"absolute bottom-0 left-0 w-3 h-3 border-l border-b border-white/40\" data-kid=\"39\"></div>\n              </button>\n              \n              <button class=\"group flex items-center gap-6 text-white font-bold tracking-[0.5em] uppercase text-xs\" data-kid=\"40\">\n                <span class=\"opacity-40 group-hover:opacity-100 transition-opacity\" data-kid=\"41\">Technical Blueprint</span>\n                <div class=\"w-12 h-[1px] bg-white/20 group-hover:w-20 group-hover:bg-white transition-all duration-500\" data-kid=\"42\"></div>\n              </button>\n            </div>\n          </div>\n        </div>\n\n        \n        <div class=\"mt-auto opacity-20 flex items-center gap-12\" data-kid=\"43\">\n          <span class=\"text-[9px] font-mono tracking-[0.6em]\" data-kid=\"88\">REF_04-99X_SYST_ACTIVE</span>\n          <div class=\"flex-1 h-[1px] bg-gradient-to-r from-white/20 to-transparent\" data-kid=\"89\"></div>\n          <div class=\"w-2 h-2 border border-white rotate-45\" data-kid=\"90\"></div>\n        </div>\n      </div>\n\n      \n      <div class=\"w-[480px] h-full flex flex-col justify-center items-center pr-16 relative z-30\" data-kid=\"44\">\n        <div class=\"w-full aspect-[3/4] border border-white/10 p-3 bg-white/[0.02] backdrop-blur-xl group relative animate-float-slow\" data-kid=\"45\">\n          <div class=\"absolute inset-0 overflow-hidden\" data-kid=\"46\">\n            <img \n              src=\"https://images.unsplash.com/photo-1561233835-f937539b95b9?auto=format&w=800&q=80&fit=crop\" \n              alt=\"Server\" \n              class=\"w-full h-full object-cover opacity-60 group-hover:opacity-90 group-hover:scale-110 transition-all duration-[3000ms]\"\n              decoding=\"async\" \n              loading=\"lazy\"\n              data-kid=\"47\"\n            >\n            <div class=\"absolute inset-0 bg-gradient-to-t from-[var(--color-bg)]/90 via-transparent to-transparent\" data-kid=\"91\"></div>\n          </div>\n          \n          \n          <div class=\"relative h-full flex flex-col justify-between p-8 z-10\" data-kid=\"48\">\n            <div class=\"flex justify-between items-start\" data-kid=\"49\">\n              <span class=\"text-[9px] font-mono tracking-widest opacity-40 uppercase\" data-kid=\"92\">MAINFRAME_DATA_STREAM</span>\n              <div class=\"w-10 h-[1px] bg-[var(--color-primary-light)]\" data-kid=\"93\"></div>\n            </div>\n            \n            <div class=\"space-y-6\" data-kid=\"50\">\n              <div class=\"flex items-center gap-3\" data-kid=\"51\">\n                <div class=\"w-2 h-2 bg-[var(--color-primary-light)] rotate-45 shadow-[0_0_8px_var(--color-primary-light)]\" data-kid=\"94\"></div>\n                <span class=\"text-[10px] font-mono text-[var(--color-primary-light)] tracking-[0.4em] uppercase\" data-kid=\"52\">NODE_092_SYNC</span>\n              </div>\n              <h3 class=\"text-3xl font-mono tracking-[0.1em] font-bold uppercase truncate\" data-kid=\"53\">SYNCHRONIZED</h3>\n              \n              \n              <div class=\"flex gap-1 items-end h-10\" data-kid=\"54\">\n                <div class=\"flex-1 bg-[var(--color-primary-light)]/40 h-[40%] animate-pulse\" data-kid=\"95\"></div>\n                <div class=\"flex-1 bg-[var(--color-primary-light)]/40 h-[90%] animate-pulse\" style=\"animation-delay: 0.2s;\" data-kid=\"96\"></div>\n                <div class=\"flex-1 bg-[var(--color-primary-light)]/40 h-[60%] animate-pulse\" style=\"animation-delay: 0.4s;\" data-kid=\"97\"></div>\n                <div class=\"flex-1 bg-[var(--color-primary-light)]/40 h-[100%] animate-pulse\" style=\"animation-delay: 0.1s;\" data-kid=\"98\"></div>\n                <div class=\"flex-1 bg-[var(--color-primary-light)]/40 h-[30%] animate-pulse\" style=\"animation-delay: 0.3s;\" data-kid=\"99\"></div>\n              </div>\n            </div>\n          </div>\n\n          \n          <div class=\"absolute -top-12 -right-12 w-48 h-48 border border-white/5 rounded-full pointer-events-none\" data-kid=\"55\"></div>\n          <span class=\"absolute -right-16 top-1/2 -translate-y-1/2 text-[9px] font-mono opacity-20 writing-vertical rotate-180 tracking-[0.8em]\" data-kid=\"56\">SECTOR_GRID_X_72</span>\n        </div>\n      </div>\n\n      \n      <aside class=\"w-[280px] h-full border-l border-white/10 flex flex-col justify-around py-32 pl-12 pr-8 relative z-40 bg-[var(--color-bg)]/80 backdrop-blur-md\" data-kid=\"57\">\n        \n        \n        <div class=\"space-y-8 group transition-all\" data-kid=\"58\">\n          <div class=\"flex items-center gap-5\" data-kid=\"59\">\n            <div class=\"w-[2px] h-8 bg-[var(--color-primary-light)]/30 group-hover:h-12 group-hover:bg-[var(--color-primary-light)] transition-all duration-500\" data-kid=\"60\"></div>\n            <div class=\"space-y-1\" data-kid=\"61\">\n              <h4 class=\"text-[11px] font-mono tracking-[0.5em] uppercase opacity-30 group-hover:opacity-100 transition-opacity\" data-kid=\"62\">STABILITY</h4>\n              <span class=\"text-[8px] font-mono opacity-20 tracking-widest block uppercase\" data-kid=\"63\">FAILOVER_ACTIVE</span>\n            </div>\n          </div>\n          <div class=\"flex items-baseline gap-3 group-hover:translate-x-2 transition-transform duration-500 group-hover:text-[var(--color-primary-light)]\" data-kid=\"64\">\n            <span class=\"text-7xl font-black tracking-tighter leading-none shadow-[0_0_30px_rgba(155,166,211,0)] group-hover:shadow-[0_0_30px_rgba(155,166,211,0.2)]\" data-kid=\"65\">99.9</span>\n            <span class=\"text-2xl opacity-20 font-light\" data-kid=\"66\">%</span>\n          </div>\n        </div>\n\n        \n        <div class=\"space-y-8 group transition-all\" data-kid=\"67\">\n          <div class=\"flex items-center gap-5\" data-kid=\"68\">\n            <div class=\"w-[2px] h-8 bg-[var(--color-primary-light)]/30 group-hover:h-12 group-hover:bg-[var(--color-primary-light)] transition-all duration-500\" data-kid=\"69\"></div>\n            <div class=\"space-y-1\" data-kid=\"70\">\n              <h4 class=\"text-[11px] font-mono tracking-[0.5em] uppercase opacity-30 group-hover:opacity-100 transition-opacity\" data-kid=\"71\">LATENCY</h4>\n              <span class=\"text-[8px] font-mono opacity-20 tracking-widest block uppercase\" data-kid=\"72\">EDGE_RESPONSE</span>\n            </div>\n          </div>\n          <div class=\"flex items-baseline gap-3 group-hover:translate-x-2 transition-transform duration-500\" data-kid=\"73\">\n            <span class=\"text-7xl font-black tracking-tighter leading-none\" data-kid=\"74\"