order-t border-white/5\" data-kid=\"218\">\n    <div class=\"max-w-7xl mx-auto\" data-kid=\"219\">\n      <div class=\"grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-20 mb-32\" data-kid=\"220\">\n        <div class=\"lg:col-span-1\" data-kid=\"221\">\n          <div class=\"flex items-center gap-3 mb-10\" data-kid=\"222\">\n            <div class=\"w-10 h-10 bg-[#D4AF37] rounded-sm flex items-center justify-center\" data-kid=\"223\">\n              <span class=\"text-[#0A1128] font-black text-sm\" data-kid=\"224\">EX</span>\n            </div>\n            <span class=\"font-serif text-2xl font-bold tracking-tight text-white\" data-kid=\"225\">EduTechEx</span>\n          </div>\n          <p class=\"text-white/40 text-sm leading-relaxed mb-10 max-w-xs\" data-kid=\"226\">\n            The global standard for institutional intelligence. Designing the future of academic operations with precision.\n          </p>\n          <div class=\"flex gap-8\" data-kid=\"227\">\n            <a href=\"#\" class=\"text-white/20 hover:text-[#D4AF37] transition-colors\" data-kid=\"228\"><i class=\"ti ti-brand-linkedin text-2xl\" data-kid=\"229\"></i></a>\n            <a href=\"#\" class=\"text-white/20 hover:text-[#D4AF37] transition-colors\" data-kid=\"230\"><i class=\"ti ti-brand-twitter text-2xl\" data-kid=\"231\"></i></a>\n            <a href=\"#\" class=\"text-white/20 hover:text-[#D4AF37] transition-colors\" data-kid=\"232\"><i class=\"ti ti-brand-instagram text-2xl\" data-kid=\"233\"></i></a>\n          </div>\n        </div>\n\n        <div data-kid=\"234\">\n          <h4 class=\"text-white font-bold text-[10px] tracking-[0.4em] uppercase mb-12\" data-kid=\"235\">System</h4>\n          <ul class=\"space-y-8 text-white/40 text-sm font-medium\" data-kid=\"236\">\n            <li data-kid=\"237\"><a href=\"#\" class=\"hover:text-[#D4AF37] transition-colors\" data-kid=\"238\">Core Intelligence</a></li>\n            <li data-kid=\"239\"><a href=\"#\" class=\"hover:text-[#D4AF37] transition-colors\" data-kid=\"240\">Curriculum OS</a></li>\n            <li data-kid=\"241\"><a href=\"#\" class=\"hover:text-[#D4AF37] transition-colors\" data-kid=\"242\">Research Hub</a></li>\n            <li data-kid=\"243\"><a href=\"#\" class=\"hover:text-[#D4AF37] transition-colors\" data-kid=\"244\">Task Automation</a></li>\n          </ul>\n        </div>\n\n        <div data-kid=\"245\">\n          <h4 class=\"text-white font-bold text-[10px] tracking-[0.4em] uppercase mb-12\" data-kid=\"246\">Academy</h4>\n          <ul class=\"space-y-8 text-white/40 text-sm font-medium\" data-kid=\"247\">\n            <li data-kid=\"248\"><a href=\"#\" class=\"hover:text-[#D4AF37] transition-colors\" data-kid=\"249\">Faculty Training</a></li>\n            <li data-kid=\"250\"><a href=\"#\" class=\"hover:text-[#D4AF37] transition-colors\" data-kid=\"251\">Partnership Programs</a></li>\n            <li data-kid=\"252\"><a href=\"#\" class=\"hover:text-[#D4AF37] transition-colors\" data-kid=\"253\">Case Studies</a></li>\n            <li data-kid=\"254\"><a href=\"#\" class=\"hover:text-[#D4AF37] transition-colors\" data-kid=\"255\">Institutional Docs</a></li>\n          </ul>\n        </div>\n\n        <div data-kid=\"256\">\n          <h4 class=\"text-white font-bold text-[10px] tracking-[0.4em] uppercase mb-12\" data-kid=\"257\">Contact</h4>\n          <div class=\"space-y-10\" data-kid=\"258\">\n            <div class=\"flex items-start gap-5\" data-kid=\"259\">\n              <i class=\"ti ti-map-pin text-[#D4AF37] text-xl mt-1\" data-kid=\"260\"></i>\n              <span class=\"text-white/40 text-sm leading-relaxed\" data-kid=\"261\">\n                1200 Harvard Yard,<br data-kid=\"262\"> Cambridge, MA 02138\n              </span>\n            </div>\n            <div class=\"flex items-start gap-5\" data-kid=\"263\">\n              <i class=\"ti ti-mail text-[#D4AF37] text-xl mt-1\" data-kid=\"264\"></i>\n              <span class=\"text-white/40 text-sm\" data-kid=\"265\">inquiry@edutechex.com</span>\n            </div>\n          </div>\n        </div>\n      </div>\n\n      <div class=\"pt-16 border-t border-white/5 flex flex-col md:flex-row justify-between items-center gap-10\" data-kid=\"266\">\n        <div class=\"text-white/30 text-xs font-bold tracking-[0.3em] uppercase\" data-kid=\"267\">\n          © 2024 EduTechEx. All Rights Reserved. Institutional Privacy Policy.\n        </div>\n        <div class=\"flex items-center gap-12 text-white/30 text-xs font-bold tracking-[0.3em] uppercase\" data-kid=\"268\">\n          <a href=\"#\" class=\"hover:text-white transition-colors\" data-kid=\"269\">Terms of Service</a>\n          <a href=\"#\" class=\"hover:text-white transition-colors\" data-kid=\"270\">Security</a>\n          <a href=\"#\" class=\"hover:text-white transition-colors\" data-kid=\"271\">Compliance</a>\n        </div>\n      </div>\n    </div>\n  </footer>\n</div>\n",
