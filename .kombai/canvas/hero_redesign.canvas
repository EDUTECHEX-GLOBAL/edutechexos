      "html": "\n<div class=\"relative w-full h-[900px] overflow-hidden bg-[#07090E] font-sans selection:bg-amber-500/30\" data-kid=\"0\">\n    \n    <style data-kid=\"1\">\n        @import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap');\n        @import url('https://api.fontshare.com/v2/css?f[]=cabinet-grotesk@800,900&display=swap');\n        @import url('https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css');\n\n        .font-display { font-family: 'Cabinet Grotesk', sans-serif; }\n        \n        @keyframes shimmer-gold {\n            0% { border-color: rgba(212, 175, 55, 0.2); box-shadow: 0 0 0px rgba(212, 175, 55, 0); }\n            50% { border-color: rgba(255, 215, 0, 0.6); box-shadow: 0 0 15px rgba(255, 215, 0, 0.1); }\n            100% { border-color: rgba(212, 175, 55, 0.2); box-shadow: 0 0 0px rgba(212, 175, 55, 0); }\n        }\n\n        @keyframes light-streak-move {\n            0% { transform: translate(-100%, -100%) rotate(-45deg); opacity: 0; }\n            10% { opacity: 0.4; }\n            90% { opacity: 0.4; }\n            100% { transform: translate(100%, 100%) rotate(-45deg); opacity: 0; }\n        }\n\n        @keyframes bar-glow {\n            0%, 100% { filter: brightness(1) drop-shadow(0 0 2px rgba(251, 191, 36, 0.3)); }\n            50% { filter: brightness(1.3) drop-shadow(0 0 8px rgba(251, 191, 36, 0.6)); }\n        }\n\n        .shimmer-border {\n            animation: shimmer-gold 4s infinite ease-in-out;\n        }\n\n        .bar-glow-animate {\n            animation: bar-glow 3s infinite ease-in-out;\n        }\n\n        .gold-text-gradient {\n            background: linear-gradient(135deg, #F9E29B 0%, #D4AF37 40%, #8A6D3B 100%);\n            -webkit-background-clip: text;\n            -webkit-text-fill-color: transparent;\n        }\n\n        .grain-overlay {\n            background-image: url(\"data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noiseFilter'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.65' numOctaves='3' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noiseFilter)'/%3E%3C/svg%3E\");\n            opacity: 0.04;\n            pointer-events: none;\n        }\n\n        .diagonal-divider {\n            clip-path: polygon(0 0, 100% 0, 85% 100%, 0% 100%);\n        }\n\n        .diagonal-line {\n            height: 100%;\n            width: 2px;\n            background: linear-gradient(to bottom, transparent, rgba(212, 175, 55, 0.5), transparent);\n            position: absolute;\n            right: 15%;\n            top: 0;\n            z-index: 5; /* Lowered to stay behind main floating elements if needed */\n        }\n    </style>\n\n    \n    <div class=\"absolute inset-0 grain-overlay z-[60]\" data-kid=\"2\"></div>\n\n    \n    <div class=\"absolute inset-0 z-0\" data-kid=\"3\">\n        \n        <div class=\"absolute top-1/2 left-1/4 -translate-x-1/2 -translate-y-1/2 w-[800px] h-[800px] bg-amber-500/10 rounded-full blur-[120px] opacity-40\" data-kid=\"4\"></div>\n        <div class=\"absolute top-1/3 right-1/4 -translate-y-1/2 w-[600px] h-[600px] bg-indigo-500/10 rounded-full blur-[100px] opacity-30\" data-kid=\"5\"></div>\n        \n        \n        <div class=\"absolute inset-0 overflow-hidden pointer-events-none\" data-kid=\"6\">\n            <div class=\"absolute top-[-50%] left-[-50%] w-[200%] h-[200%] animate-[light-streak-move_15s_linear_infinite]\" data-kid=\"7\">\n                <div class=\"absolute w-[1px] h-full bg-white/10 left-1/4\" data-kid=\"8\"></div>\n                <div class=\"absolute w-[1px] h-full bg-white/5 left-1/2\" data-kid=\"9\"></div>\n                <div class=\"absolute w-[1px] h-full bg-white/10 left-3/4\" data-kid=\"10\"></div>\n            </div>\n            <div class=\"absolute top-[-50%] left-[-50%] w-[200%] h-[200%] animate-[light-streak-move_20s_linear_infinite_5s]\" data-kid=\"11\">\n                <div class=\"absolute w-[2px] h-full bg-amber-400/10 left-[40%]\" data-kid=\"12\"></div>\n                <div class=\"absolute w-[1px] h-full bg-white/5 left-[60%]\" data-kid=\"13\"></div>\n            </div>\n        </div>\n    </div>\n\n    \n    <div class=\"relative z-10 w-full h-full flex\" data-kid=\"14\">\n        \n        \n        <div class=\"w-[55%] h-full bg-[#07090E] diagonal-divider relative px-20 flex flex-col justify-center\" data-kid=\"15\">\n            \n            <div class=\"absolute top-12 left-20 flex items-center gap-3 group cursor-pointer\" data-kid=\"16\">\n                <div class=\"w-10 h-10 bg-amber-400 rounded-lg flex items-center justify-center font-display font-black text-[#07090E] text-xl shadow-[0_0_25px_rgba(251,191,36,0.4)] group-hover:scale-110 transition-transform\" data-kid=\"17\">EX</div>\n                <div data-kid=\"18\">\n                    <div class=\"text-white font-display font-black tracking-tighter text-lg leading-none\" data-kid=\"19\">EduTechExOS</div>\n                    <div class=\"text-slate-500 text-[10px] tracking-[0.3em] uppercase mt-1\" data-kid=\"20\">Institutional OS</div>\n                </div>\n            </div>\n\n            \n            <div class=\"max-w-2xl\" data-kid=\"21\">\n                <div class=\"inline-flex items-center gap-3 px-4 py-1.5 rounded-full border border-white/10 bg-white/5 backdrop-blur-md mb-10 shimmer-border\" data-kid=\"22\">\n                    <span class=\"flex h-2 w-2 relative\" data-kid=\"23\">\n                        <span class=\"animate-ping absolute inline-flex h-full w-full rounded-full bg-amber-400 opacity-75\" data-kid=\"24\"></span>\n                        <span class=\"relative inline-flex rounded-full h-2 w-2 bg-amber-500\" data-kid=\"25\"></span>\n                    </span>\n                    <span class=\"text-[10px] font-mono font-semibold text-amber-100/90 uppercase tracking-[0.25em]\" data-kid=\"26\">