      "html": "\n<section class=\"bg-[#191E2F] text-[#FAF8F5] font-['Inter'] overflow-hidden py-32 px-6 relative h-[1200px] flex flex-col items-center\" data-kid=\"0\">\n    \n    <style data-kid=\"1\">\n        @import url('https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap');\n        @import url('https://api.fontshare.com/v2/css?f[]=cabinet-grotesk@400,500,700,800,900&display=swap');\n        @import url('https://cdn.jsdelivr.net/npm/@tabler/icons-webfont/tabler-icons.min.css');\n\n        .perspective-2000 {\n            perspective: 2000px;\n        }\n\n        .metallic-border {\n            box-shadow: \n                0 0 0 2px rgba(155, 166, 211, 0.4),\n                0 0 60px rgba(62, 74, 137, 0.6),\n                inset 0 0 30px rgba(155, 166, 211, 0.3);\n        }\n\n        .shimmer-text {\n            background: linear-gradient(90deg, #FAF8F5 0%, #c4b5fd 50%, #FAF8F5 100%);\n            background-size: 200% auto;\n            -webkit-background-clip: text;\n            -webkit-text-fill-color: transparent;\n            animation: shimmer 4s linear infinite;\n        }\n\n        @keyframes shimmer {\n            0% { background-position: -200% center; }\n            100% { background-position: 200% center; }\n        }\n\n        @keyframes aurora-1 {\n            0%, 100% { transform: translate(0, 0) scale(1); opacity: 0.35; }\n            25% { transform: translate(10%, -10%) scale(1.1); opacity: 0.45; }\n            50% { transform: translate(-5%, 15%) scale(0.95); opacity: 0.30; }\n            75% { transform: translate(8%, 5%) scale(1.05); opacity: 0.40; }\n        }\n\n        @keyframes aurora-2 {\n            0%, 100% { transform: translate(0, 0) scale(1); opacity: 0.25; }\n            25% { transform: translate(-8%, 12%) scale(1.15); opacity: 0.35; }\n            50% { transform: translate(12%, -8%) scale(0.9); opacity: 0.20; }\n            75% { transform: translate(-5%, 10%) scale(1.1); opacity: 0.30; }\n        }\n\n        @keyframes float {\n            0%, 100% { transform: translateY(0px) rotateX(12deg) rotateY(-4deg) rotate(2deg); }\n            50% { transform: translateY(-20px) rotateX(10deg) rotateY(-2deg) rotate(3deg); }\n        }\n\n        @keyframes float-simple {\n            0%, 100% { transform: translateY(0px); }\n            50% { transform: translateY(-15px); }\n        }\n\n        @keyframes glow-pulse {\n            0%, 100% { transform: scale(1); opacity: 0.1; }\n            50% { transform: scale(1.1); opacity: 0.15; }\n        }\n\n        @keyframes neon-pulse {\n            0%, 100% { opacity: 0.4; filter: brightness(1); }\n            50% { opacity: 1; filter: brightness(1.5) drop-shadow(0 0 5px #a78bfa); }\n        }\n\n        @keyframes fade-up {\n            from { opacity: 0; transform: translateY(30px); }\n            to { opacity: 1; transform: translateY(0); }\n        }\n\n        @keyframes fade-down {\n            from { opacity: 0; transform: translateY(-20px); }\n            to { opacity: 1; transform: translateY(0); }\n        }\n\n        @keyframes scale-in {\n            from { opacity: 0; transform: scale(0.95) translateY(20px); }\n            to { opacity: 1; transform: scale(1) translateY(0); }\n        }\n\n        .animate-aurora-1 { animation: aurora-1 20s ease-in-out infinite; }\n        .animate-aurora-2 { animation: aurora-2 25s ease-in-out infinite; }\n        .animate-glow-pulse { animation: glow-pulse 5s ease-in-out infinite; }\n        .animate-float { animation: float 8s ease-in-out infinite; }\n        .animate-float-simple { animation: float-simple 6s ease-in-out infinite; }\n        .animate-neon-pulse { animation: neon-pulse 2s ease-in-out infinite; }\n        .animate-fade-up { animation: fade-up 0.8s cubic-bezier(0.2, 0.8, 0.2, 1) forwards; }\n        .animate-fade-down { animation: fade-down 0.8s cubic-bezier(0.2, 0.8, 0.2, 1) forwards; }\n        .animate-scale-in { animation: scale-in 1s cubic-bezier(0.2, 0.8, 0.2, 1) forwards; }\n        .animate-shimmer { animation: shimmer 2.5s linear infinite; }\n\n        .aurora-blur {\n            filter: blur(140px);\n        }\n    </style>\n\n    \n    <div class=\"absolute inset-0 overflow-hidden pointer-events-none\" data-kid=\"2\">\n        \n        <div class=\"absolute top-[-20%] left-[-10%] w-[800px] h-[800px] bg-[#3E4A89]/30 rounded-full aurora-blur animate-aurora-1\" data-kid=\"3\"></div>\n        <div class=\"absolute bottom-[-20%] right-[-10%] w-[900px] h-[900px] bg-[#a78bfa]/25 rounded-full aurora-blur animate-aurora-2 delay-1000\" data-kid=\"4\"></div>\n        <div class=\"absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[1200px] h-[1200px] bg-[#3E4A89]/10 rounded-full blur-[200px] animate-glow-pulse\" data-kid=\"5\"></div>\n        \n        \n        <div class=\"absolute top-1/4 left-[-10%] w-full h-[400px] bg-linear-to-r from-transparent via-[#a78bfa]/10 to-transparent rotate-12 animate-aurora-1 opacity-40\" data-kid=\"6\"></div>\n        <div class=\"absolute bottom-1/4 right-[-10%] w-full h-[500px] bg-linear-to-r from-transparent via-[#3E4A89]/15 to-transparent -rotate-12 animate-aurora-2 opacity-40\" data-kid=\"7\"></div>\n    </div>\n\n    \n    <div class=\"relative z-10 text-center flex flex-col items-center max-w-5xl\" data-kid=\"8\">\n        \n        <div class=\"inline-flex items-center gap-2 px-4 py-1.5 rounded-full bg-[#3E4A89]/10 border border-[#3E4A89]/30 text-[#9BA6D3] text-xs font-mono mb-10 animate-fade-down uppercase tracking-widest\" data-kid=\"9\">\n            <span class=\"w-1.5 h-1.5 rounded-full bg-[#a78bfa] animate-neon-pulse shadow-[0_0_10px_#a78bfa]\" data-kid=\"10\"></span>\n            System Version 4.0 // Deployment Live\n        </div>\n        \n        \n        <h1 class=\"font-['Cabinet_Grotesk'] text-[clamp(4rem,10vw,140px)] tracking-tight mb-8 animate-fade-up leading-[0.85] flex flex-col items-center font-black\" data-kid=\"11\">\n            <span class=\"block opacity-90 font-medium text-[0.6em] tracking-tighter mb-2\" data-kid=\"12\">Architecting the</span>\n            <span class=\"shimmer-text\" data-kid=\"13\">Midnight Aurora</span>\n        </h1>\n        \n        \n        <p class=\"text-[#FAF8F5]/70 text-xl md:text-2xl font-light max-w-3xl mb-12 animate-fade-up opacity-0 leading-relaxed\" style=\"animation-delay: 200ms;\" data-kid=\"14\">\n            A high-fidelity creative workspace engineered for professionals who demand <span class=\"text-[#a78bfa] font-medium italic\" data-kid=\"15\">absolute precision</span> and cinematic flow.\n        </p>\n        \n        \n        <button class=\"group relative px-10 py-5 bg-[#3E4A89] text-[#FAF8F5] rounded-2xl font-bold shadow-[0_0_40px_-8px_rgba(62,74,137,0.3)] text-lg overflow-hidden transition-all hover:scale-[1.02] active:scale-95 animate-fade-up opacity-0\" style=\"animation-delay: 400ms;\" data-kid=\"16\">\n            <span class=\"relative z-10 flex items-center gap-3\" data-kid=\"17\">\n                Experience the Interface\n                <i class=\"ti ti-circle-arrow-right-filled text-2xl group-hover:translate-x-1 transition-transform\" data-kid=\"18\"></i>\n            </span>\n            \n            <div class=\"absolute inset-0 bg-linear-to-r from-transparent via-white/10 to-transparent -translate-x-full group-hover:animate-shimmer\" data-kid=\"19\"></div>\n        </button>\n    </div>\n\n    \n    <div class=\"relative z-10 mt-12 w-full max-w-6xl animate-scale-in opacity-0 perspective-2000 px-4\" style=\"animation-delay: 600ms;\" data-kid=\"20\">\n        <div class=\"relative group\" data-kid=\"21\">\n            \n            <div class=\"absolute inset-0 bg-[#3E4A89]/30 blur-[120px] transform rotate-x-12 opacity-40\" data-kid=\"22\"></div>\n            \n            \n            <div class=\"w-full aspect-[16/9] bg-[#191E2F]/95 rounded-[2rem] metallic-border backdrop-blur-3xl transform rotate-x-12 rotate-y-[-4deg] rotate-2 animate-float border border-white/15 overflow-hidden\" data-kid=\"23\">\n                \n                <div class=\"h-full flex flex-col\" data-kid=\"24\">\n                    \n                    <div class=\"h-16 border-b border-white/10 flex items-center justify-between px-8 bg-white/5\" data-kid=\"25\">\n                        <div class=\"flex items-center gap-6\" data-kid=\"26\">\n                            <div class=\"flex gap-2\" data-kid=\"27\">\n                                <div class=\"w-3.5 h-3.5 rounded-full bg-red-500/50 border border-red-500/30\" data-kid=\"28\"></div>\n                                <div class=\"w-3.5 h-3.5 rounded-full bg-yellow-500/50 border border-yellow-500/30\" data-kid=\"29\"></div>\n                                <div class=\"w-3.5 h-3.5 rounded-full bg-green-500/50 border border-green-500/30\" data-kid=\"30\"></div>\n                            </div>\n                            <div class=\"h-6 w-px bg-white/20\" data-kid=\"31\"></div>\n                            <div class=\"flex items-center gap-2 text-primary-light font-mono text-sm\" data-kid=\"32\">\n                                <i class=\"ti ti-lock\" data-kid=\"33\"></i>\n                                dashboard.aurora.io\n                            </div>\n                        </div>\n                        <div class=\"flex items-center gap-4\" data-kid=\"34\">\n                            <div class=\"w-8 h-8 rounded-full bg-primary/30 border border-primary/50\" data-kid=\"35\"></div>\n                            <div class=\"w-24 h-2 bg-white/20 rounded-full\" data-kid=\"36\"></div>\n                        </div>\n                    </div>\n\n                    \n                    <div class=\"flex-1 flex gap-px bg-white/10\" data-kid=\"37\">\n                        \n                        <div class=\"w-64 bg-white/5 p-6 flex flex-col gap-6\" data-kid=\"38\">\n                            <div class=\"space-y-4\" data-kid=\"39\">\n                                <div class=\"h-8 w-full bg-[#3E4A89]/30 rounded-lg border border-[#3E4A89]/30\" data-kid=\"40\"></div>\n                                <div class=\"h-8 w-full bg-white/10 rounded-lg\" data-kid=\"41\"></div>\n                                <div class=\"h-8 w-full bg-white/10 rounded-lg\" data-kid=\"42\"></div>\n                                <div class=\"h-8 w-full bg-white/10 rounded-lg\" data-kid=\"43\"></div>\n                            </div>\n                            <div class=\"mt-auto h-24 bg-[#a78bfa]/20 rounded-xl border border-[#a78bfa]/30 p-4\" data-kid=\"44\">\n                                <div class=\"w-3/4 h-2.5 bg-[#a78bfa]/40 rounded mb-3\" data-kid=\"45\"></div>\n                                <div class=\"w-full h-1.5 bg-white/10 rounded\" data-kid=\"46\"></div>\n                            </div>\n                        </div>\n\n                        \n                        <div class=\"flex-1 p-8 grid grid-cols-3 gap-6\" data-kid=\"47\">\n                            <div class=\"col-span-2 space-y-6\" data-kid=\"48\">\n                                <div class=\"h-52 rounded-2xl bg-[#3E4A89]/20 border border-[#3E4A89]/20 p-6 flex flex-col justify-end\" data-kid=\"49\">\n                                    <div class=\"w-1/3 h-6 bg-[#3E4A89]/30 rounded-md mb-6\" data-kid=\"50\"></div>\n                                    <div class=\"flex gap-3 items-end h-32\" data-kid=\"51\">\n                                        <div class=\"flex-1 h-[40%] bg-[#3E4A89]/40 rounded-t-lg\" data-kid=\"52\"></div>\n                                        <div class=\"flex-1 h-[80%] bg-[#a78bfa]/40 rounded-t-lg\" data-kid=\"53\"></div>\n                                        <div class=\"flex-1 h-[60%] bg-[#3E4A89]/40 rounded-t-lg\" data-kid=\"54\"></div>\n                                        <div class=\"flex-1 h-[30%] bg-[#3E4A89]/30 rounded-t-lg\" data-kid=\"55\"></div>\n                                        <div class=\"flex-1 h-[90%] bg-[#a78bfa]/50 rounded-t-lg shadow-[0_0_20px_rgba(196,181,253,0.3)]\" data-kid=\"56\"></div>\n                                        <div class=\"flex-1 h-[50%] bg-[#3E4A89]/40 rounded-t-lg\" data-kid=\"57\"></div>\n                                    </div>\n                                </div>\n                                <div class=\"grid grid-cols-2 gap-6\" data-kid=\"58\">\n                                    <div class=\"h-36 bg-white/5 rounded-2xl border border-white/10 p-5 flex flex-col justify-center gap-4 transition-colors hover:bg-white/8\" data-kid=\"59\">\n                                        <div class=\"w-12 h-12 rounded-xl bg-[#a78bfa]/30 flex items-center justify-center text-[#a78bfa] shadow-[0_0_15px_rgba(167,139,250,0.2)]\" data-kid=\"60\">\n                                            <i class=\"ti ti-activity-heartbeat text-2xl\" data-kid=\"61\"></i>\n                                        </div>\n                                        <div class=\"w-3/4 h-2.5 bg-white/20 rounded\" data-kid=\"62\"></div>\n                                    </div>\n                                    <div class=\"h-36 bg-white/5 rounded-2xl border border-white/10 p-5 flex flex-col justify-center gap-4 transition-colors hover:bg-white/8\" data-kid=\"63\">\n                                        <div class=\"w-12 h-12 rounded-xl bg-[#3E4A89]/40 flex items-center justify-center text-[#9BA6D3] shadow-[0_0_15px_rgba(62,74,137,0.2)]\" data-kid=\"64\">\n                                            <i class=\"ti ti-users text-2xl\" data-kid=\"65\"></i>\n                                        </div>\n                                        <div class=\"w-3/4 h-2.5 bg-white/20 rounded\" data-kid=\"66\"></div>\n                                    </div>\n                                </div>\n                            </div>\n                            <div class=\"bg-white/5 rounded-2xl border border-white/10 p-8 space-y