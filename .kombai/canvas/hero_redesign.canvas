      "html": "\n<body class=\"bg-[#F9F8F6] font-sans antialiased text-[#1E2636]\">\n  <style data-kid=\"0\">\n    @import url('https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,700;1,400;1,700&family=Inter:wght@400;500;600;700;800;900&display=swap');\n    @import url('https://cdn.jsdelivr.net/npm/@tabler/icons-webfont/tabler-icons.min.css');\n\n    .font-serif { font-family: 'Playfair Display', serif; }\n    .font-sans { font-family: 'Inter', sans-serif; }\n\n    /* Layout Clip Path */\n    .hero-diag {\n      clip-path: polygon(0 0, 100% 0, 87% 100%, 0 100%);\n    }\n    @media (max-width: 1023px) {\n      .hero-diag { clip-path: none; width: 100%; }\n    }\n\n    /* Animations */\n    @keyframes fade-up {\n      from { opacity: 0; transform: translateY(24px); }\n      to { opacity: 1; transform: translateY(0); }\n    }\n    @keyframes typing {\n      0%, 100% { opacity: 0.3; }\n      50% { opacity: 1; }\n    }\n    .typing-dot { animation: typing 1s infinite; }\n    .animate-fade-up {\n      animation: fade-up 0.8s cubic-bezier(0.22, 1, 0.36, 1) both;\n    }\n\n    @keyframes float-a {\n      0%, 100% { transform: translateY(0px) rotate(-1deg); }\n      50% { transform: translateY(-20px) rotate(0.5deg); }\n    }\n    @keyframes float-b {\n      0%, 100% { transform: translateY(0px) rotate(1.2deg); }\n      50% { transform: translateY(-25px) rotate(-0.4deg); }\n    }\n    @keyframes float-c {\n      0%, 100% { transform: translateY(0px) rotate(-0.8deg); }\n      50% { transform: translateY(-15px) rotate(0.6deg); }\n    }\n\n    .float-a { animation: float-a 7s ease-in-out infinite; }\n    .float-b { animation: float-b 9s ease-in-out infinite 1s; }\n    .float-c { animation: float-c 6.5s ease-in-out infinite 0.5s; }\n\n    @keyframes orb-pulse {\n      0%, 100% { opacity: 0.1; filter: blur(72px); transform: scale(1); }\n      50% { opacity: 0.22; filter: blur(84px); transform: scale(1.1); }\n    }\n    .orb-pulse { animation: orb-pulse 10s ease-in-out infinite; }\n\n    /* Card Styling */\n    .glass-card {\n      background: rgba(255, 255, 255, 0.94);\n      backdrop-filter: blur(32px) saturate(170%);\n      border-radius: 18px;\n      border: 1px solid rgba(10, 17, 40, 0.07);\n      box-shadow: \n        0 1px 0 rgba(255, 255, 255, 0.95) inset,\n        0 1px 2px rgba(10, 17, 40, 0.04),\n        0 4px 12px rgba(10, 17, 40, 0.05),\n        0 16px 40px rgba(10, 17, 40, 0.08),\n        0 36px 64px rgba(10, 17, 40, 0.05);\n    }\n\n    .dot-grid-navy {\n      background-image: radial-gradient(rgba(212, 175, 55, 0.09) 1px, transparent 1px);\n      background-size: 30px 30px;\n    }\n    .dot-grid-bone {\n      background-image: radial-gradient(rgba(10, 17, 40, 0.042) 1px, transparent 1px);\n      background-size: 24px 24px;\n    }\n\n    .tracking-institutional { letter-spacing: 0.38em; }\n    .tracking-sub { letter-spacing: 0.28em; }\n    .tracking-button { letter-spacing: 0.26em; }\n  </style>\n\n  <section class=\"relative w-full min-h-[900px] flex flex-col lg:flex-row overflow-hidden bg-[#F9F8F6]\" data-kid=\"1\">\n    \n    \n    <div class=\"hero-diag relative lg:w-[54%] bg-[#0A1128] z-20 flex flex-col justify-center px-8 md:px-16 lg:px-24 xl:px-32 py-24 min-h-[900px]\" data-kid=\"2\">\n      \n      <div class=\"absolute inset-0 dot-grid-navy pointer-events-none\" data-kid=\"3\"></div>\n      \n      \n      <div class=\"absolute -top-[15%] -left-[10%] w-[500px] h-[500px] rounded-full bg-radial from-[#D4AF37]/15 to-transparent orb-pulse\" data-kid=\"4\"></div>\n      <div class=\"absolute bottom-[5%] right-[10%] w-[350px] h-[350px] rounded-full bg-radial from-[#3E4A89]/12 to-transparent blur-[60px]\" data-kid=\"5\"></div>\n\n      \n      <div class=\"absolute top-0 right-0 w-[240px] h-[240px] overflow-hidden hidden lg:block\" data-kid=\"6\">\n        <div class=\"absolute -top-[120px] -right-[120px] w-[220px] h-[220px] rounded-full border border-[#D4AF37]/15\" data-kid=\"7\"></div>\n        <div class=\"absolute -top-[87px] -right-[87px] w-[155px] h-[155px] rounded-full border border-[#D4AF37]/10\" data-kid=\"8\"></div>\n        <div class=\"absolute -top-[55px] -right-[55px] w-[90px] h-[90px] rounded-full border border-[#D4AF37]/5\" data-kid=\"9\"></div>\n      </div>\n\n      \n      <div class=\"relative z-10 max-w-[540px]\" data-kid=\"10\">\n        \n        <div class=\"flex items-center gap-4 mb-12 animate-fade-up [animation-delay:100ms]\" data-kid=\"11\">\n          <div class=\"w-9 h-9 rounded-md bg-[#D4AF37] flex items-center justify-center shadow-[0_4px_16px_rgba(212,175,55,0.3)]\" data-kid=\"12\">\n            <span class=\"text-[#0A1128] text-xs font-black\" data-kid=\"13\">EX</span>\n          </div>\n          <span class=\"text-xs font-black uppercase text-[#D4AF37]/70 tracking-institutional\" data-kid=\"14\">Institutional Operating System</span>\n        </div>\n\n        <div class=\"w-[60px] h-[2px] bg-[#D4AF37]/50 rounded-full mb-10 animate-fade-up [animation-delay:200ms]\" data-kid=\"15\"></div>\n\n        \n        <h1 class=\"font-serif text-white text-5xl md:text-7xl xl:text-[82px] font-bold leading-[1.05] tracking-tight mb-10 animate-fade-up [animation-delay:300ms] max-w-[16ch]\" data-kid=\"16\">\n          The Team OS <i class=\"text-[#D4AF37] font-normal italic block md:inline\" data-kid=\"17\">EduTechEx</i> Runs On.\n        </h1>\n\n        \n        <div class=\"flex items-center gap-3 mb-8 animate-fade-up [animation-delay:400ms]\" data-kid=\"18\">\n          <div class=\"w-10 h-px bg-[#D4AF37]/40\" data-kid=\"19\"></div>\n          <span class=\"text-xs font-extrabold uppercase text-[#D4AF37]/60 tracking-sub\" data-kid=\"20\">Channels · AI · Tasks · Digests</span>\n        </div>\n\n        \n        <p class=\"text-[#F9F8F6]/45 text-lg leading-relaxed mb-12 max-w-[42ch] animate-fade-up [animation-delay:500ms]\" data-kid=\"21\">\n          All the context your team needs — channels, embedded AI, auto-extracted tasks, and morn