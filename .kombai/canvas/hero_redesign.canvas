x-blend-screen opacity-80 blur-xs\" alt=\"Fluid 3D\" decoding=\"async\" loading=\"lazy\" data-kid=\"79\">\n                <div class=\"absolute inset-0 bg-linear-to-tr from-primary/40 to-transparent rounded-full\" data-kid=\"80\"></div>\n            </div>\n\n            \n            <div class=\"absolute -bottom-10 -right-20 w-72 h-72 animate-float delay-700 z-20\" data-kid=\"81\">\n                <img src=\"https://images.unsplash.com/photo-1655841439659-0afc60676b70?auto=format&w=500&q=80&fit=crop\" class=\"w-full h-full object-cover rounded-full mix-blend-screen opacity-60 blur-sm\" alt=\"Fluid 3D\" decoding=\"async\" loading=\"lazy\" data-kid=\"82\">\n                <div class=\"absolute inset-0 bg-linear-to-bl from-lavender/30 to-transparent rounded-full\" data-kid=\"83\"></div>\n            </div>\n\n            \n            <div class=\"absolute top-1/3 -right-20 w-40 h-40 opacity-20 blur-xs animate-float-simple z-0\" data-kid=\"84\">\n                <img src=\"https://cdn.jsdelivr.net/npm/game-icons-transparent@latest/svgs/skoll/hexes.svg\" class=\"w-full h-full brightness-0 invert\" style=\"filter: brightness(0) invert(1) drop-shadow(0 0 5px #3E4A89);\" alt=\"Hexagon\" data-kid=\"85\">\n            </div>\n\n            \n            <div class=\"absolute bottom-1/3 -left-24 w-48 h-48 opacity-15 blur-sm animate-float-simple z-0\" data-kid=\"86\">\n                <img src=\"https://cdn.jsdelivr.net/npm/game-icons-transparent@latest/svgs/lorc/transparent-tubes.svg\" class=\"w-full h-full brightness-0 invert\" style=\"filter: brightness(0) invert(1) drop-shadow(0 0 5px #a78bfa);\" alt=\"Cylinder\" data-kid=\"87\">\n            </div>\n        </div>\n    </div>\n</section>\n",
