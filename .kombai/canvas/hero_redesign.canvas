      "html": "\n<section class=\"bg-[#F2F0EC] text-[#1E2636] font-sans selection:bg-[#3E4A89]/10\" data-kid=\"0\">\n  <style data-kid=\"1\">\n    @import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;700;800;900&family=JetBrains+Mono:wght@400;500;700&display=swap');\n    @import url('https://cdn.jsdelivr.net/npm/@tabler/icons-webfont/tabler-icons.min.css');\n\n    .font-sans { font-family: 'Inter', sans-serif; }\n    .font-mono { font-family: 'JetBrains Mono', monospace; }\n\n    @keyframes slide-up {\n      from { opacity: 0; transform: translateY(80px); }\n      to { opacity: 1; transform: translateY(0); }\n    }\n\n    @keyframes pulse-signal {\n      0%, 100% { opacity: 1; transform: scale(1); }\n      50% { opacity: 0.4; transform: scale(0.8); }\n    }\n\n    .animate-slide-up {\n      animation: slide-up 1.4s cubic-bezier(0.16, 1, 0.3, 1) both;\n    }\n\n    .animate-pulse-signal {\n      animation: pulse-signal 2s infinite ease-in-out;\n    }\n\n    .grid-border {\n      border: 1px solid #E0DDE8;\n    }\n\n    .paper-texture {\n      background-image: url(\"https://www.transparenttextures.com/patterns/natural-paper.png\");\n      background-repeat: repeat;\n      opacity: 0.03;\n    }\n\n    .border-subtle {\n      border-color: #E0DDE8;\n    }\n\n    /* Custom tracking for the ultra-tight look */\n    .tracking-ultra-tight {\n      letter-spacing: -0.06em;\n    }\n  </style>\n\n  <div class=\"max-w-[1440px] mx-auto min-h-[920px] flex flex-col grid-border border-t-0 bg-[#F2F0EC] relative overflow-hidden\" data-kid=\"2\">\n    \n    <div class=\"absolute inset-0 paper-texture pointer-events-none z-50\" data-kid=\"3\"></div>\n    \n    \n    <nav class=\"h-16 flex border-b border-subtle items-center px-12 justify-between\" data-kid=\"4\">\n      <div class=\"font-mono text-[11px] font-bold uppercase tracking-[0.3em] flex items-center gap-6\" data-kid=\"5\">\n        <span class=\"text-[#3E4A89]\" data-kid=\"6\">Nexus.Editorial</span>\n        <span class=\"text-[#E0DDE8]\" data-kid=\"7\">/</span>\n        <span class=\"text-[#4A5578]/60\" data-kid=\"8\">Archive 2024</span>\n      </div>\n      <div class=\"hidden md:flex gap-12 font-mono text-[10px] uppercase tracking-widest text-[#4A5578]\" data-kid=\"9\">\n        <a href=\"#\" class=\"hover:text-[#3E4A89] transition-colors\" data-kid=\"10\">Documentation</a>\n        <a href=\"#\" class=\"hover:text-[#3E4A89] transition-colors\" data-kid=\"11\">Interface</a>\n        <a href=\"#\" class=\"hover:text-[#3E4A89] transition-colors\" data-kid=\"12\">Philosophy</a>\n      </div>\n      <div class=\"font-mono text-[10px] uppercase tracking-widest text-[#4A5578]/60\" data-kid=\"13\">\n        12:44 GMT+2\n      </div>\n    </nav>\n\n    \n    <div class=\"flex flex-1 border-b border-subtle overflow-hidden\" data-kid=\"14\">\n      \n      \n      <div class=\"w-[60%] border-r border-subtle p-12 lg:p-20 flex flex-col justify-between relative\" data-kid=\"15\">\n        <div class=\"absolute top-10 right-10 flex flex-col items-end opacity-20\" data-kid=\"16\">\n          <span class=\"font-mono text-[10px] uppercase tracking-tighter\" data-kid=\"17\">IDX / 003</span>\n          <span class=\"font-mono text-[40px] font-bold leading-none\" data-kid=\"18\">V.3</span>\n        </div>\n\n        <div class=\"space-y-4\" data-kid=\"19\">\n          <div class=\"font-mono text-[10px] uppercase tracking-[0.2em] text-[#4A5578]/50 flex items-center gap-3\" data-kid=\"20\">\n            <span class=\"w-10 h-[1px] bg-[#E0DDE8]\" data-kid=\"21\"></span>\n            Interface Paradigm\n          </div>\n          <h1 class=\"text-[clamp(4.5rem,10vw,9.5rem)] font-black tracking-ultra-tight leading-[0.88] uppercase text-[#1E2636]\" data-kid=\"22\">\n            Design<br data-kid=\"23\">\n            Beyond<br data-kid=\"24\">\n            Utility\n          </h1>\n        </div>\n\n        <div class=\"mt-12 max-w-lg space-y-10\" data-kid=\"25\">\n          <p class=\"text-xl text-[#4A5578] leading-snug font-medium border-l-[3px] border-[#3E4A89] pl-8\" data-kid=\"26\">\n            Engineered for clarity, built for impact. We transform complex data structures into seamless editorial experiences that breathe.\n          </p>\n          \n          <div class=\"flex items-center gap-8\" data-kid=\"27\">\n            <button class=\"bg-[#9BA6D3] text-[#191E2F] px-12 py-6 text-sm font-black uppercase tracking-[0.2em] flex items-center gap-6 hover:bg-[#3E4A89] hover:text-white hover:scale-[1.02] active:scale-[0.98] transition-all duration-300 group rounded-none relative overflow-hidden\" data-kid=\"28\">\n              <span class=\"relative z-10\" data-kid=\"29\">Inquire Now</span>\n              <i class=\"ti ti-arrow-move-right text-lg group-hover:translate-x-2 transition-transform relative z-10\" data-kid=\"30\"></i>\n              <div class=\"absolute inset-0 bg-[#1E2636]/10 translate-y-full group-hover:translate-y-0 transition-transform duration-300\" data-kid=\"31\"></div>\n            </button>\n            <div class=\"font-mono text-[10px] uppercase tracking-widest text-[#4A5578] font-bold max-w-[200px] leading-relaxed\" data-kid=\"32\">\n              *Limited Availability Q4 2024\n            </div>\n          </div>\n        </div>\n      </div>\n\n      \n      <div class=\"w-[40%] flex flex-col bg-white/30\" data-kid=\"33\">\n        <div class=\"flex-1 p-8 lg:p-12 flex flex-col\" data-kid=\"34\">\n          \n          <div class=\"flex-1 relative overflow-hidden grid-border group cursor-crosshair\" data-kid=\"35\">\n            <div class=\"absolute inset-0 bg-[#3E4A89]/5 group-hover:bg-transparent transition-colors duration-500 z-10\" data-kid=\"36\"></div>\n            <video src=\"https://videos.pexels.com/video-files/8303104/8303104-hd_1280_720_24fps.mp4\" poster=\"https://images.pexels.com/videos/8303104/3d-abstract-animation-background-8303104.jpeg?auto=compress&cs=tinysrgb&fit=crop&h=630&w=1200\" autoplay muted loop playsinline preload=\"metadata\" class=\"absolute inset-0 w-full h-full object-cover grayscale brightness-110 contrast-125\" data-kid=\"37\"></video>\n            \n            \n            <div class=\"absolute top-4 left-4 z-20 flex items-center gap-2\" data-kid=\"38\">\n              <div class=\"bg-white/90 backdrop-blur px-3 py-1 font-mono text-[9px] font-bold uppercase tracking-widest border border-subtle flex items-center gap-2\" data-kid=\"39\">\n                <span class=\"w-1.5 h-1.5 bg-red-500 rounded-full animate-pulse-signal\" data-kid=\"40\"></span>\n                REC 00:04:21\n              </div>\n            </div>\n            <div class=\"absolute bottom-4 right-4 z-20\" data-kid=\"41\">\n              <i class=\"ti ti-maximize text-white text-xl opacity-60\" data-kid=\"42\"></i>\n            </div>\n          </div>\n\n          \n          <div class=\"mt-8 flex justify-between items-start font-mono\" data-kid=\"43\">\n            <div class=\"space-y-1\" data-kid=\"44\">\n              <span class=\"text-[10px] font-bold uppercase tracking-widest text-[#1E2636]\" data-kid=\"45\">FIG. 01 — FLOW ANALYSIS</span>\n              <div class=\"text-[9px] text-[#4A5578]/60\" data-kid=\"46\">Source: Generative Stream / 60FPS</div>\n            </div>\n            <div class=\"text-right space-y-1\" data-kid=\"47\">\n              <span class=\"text-[10px] font-bold uppercase tracking-widest text-[#1E2636]\" data-kid=\"48\">Bitrate</span>\n              <div class=\"text-[9px] text-[#3E4A89] font-bold\" data-kid=\"49\">128 MB/S</div>\n            </div>\n          </div>\n        </div>\n\n        \n        <div class=\"h-48 border-t border-subtle grid grid-cols-2 divide-x divide-subtle\" data-kid=\"50\">\n           <div class=\"p-6 flex flex-col justify-between hover:bg-white transition-colors group cursor-help border-r border-subtle\" data-kid=\"51\">\n              <i class=\"ti ti-viewfinder text-[#3E4A89] text-xl group-hover:scale-110 transition-transform\" data-kid=\"52\"></i>\n              <div class=\"font-mono text-[10px] uppercase tracking-widest text-[#1E2636] font-bold\" data-kid=\"53\">Focus Locked</div>\n           </div>\n           <div class=\"p-6 flex flex-col justify-between bg-white/60 hover:bg-white transition-colors group cursor-help\" data-kid=\"54\">\n              <i class=\"ti ti-scan text-[#3E4A89] text-xl group-hover:rotate-90 transition-transform duration-500\" data-kid=\"55\"></i>\n              <div class=\"font-mono text-[10px] uppercase tracking-widest text-[#1E2636] font-bold\" data-kid=\"56\">Scanning...</div>\n           </div>\n        </div>\n      </div>\n    </div>\n\n    \n    <div class=\"h-[220px] flex divide-x divide-subtle group/metrics\" data-kid=\"57\">\n      \n      \n      <div class=\"flex-1 p-10 flex flex-col justify-between animate-slide-up hover:bg-white hover:translate-y-[-4px] transition-all duration-500\" style=\"animation-delay: 0.1s;\" data-kid=\"58\">\n        <div class=\"font-mono text-[10px] uppercase tracking-[0.3em] text-[#4A5578]/60 flex items-center justify-between\" data-kid=\"59\">\n          <span data-kid=\"60\">Precision</span>\n          <span class=\"opacity-0 group-hover/metrics:opacity-100 transition-opacity\" data-kid=\"61\">01</span>\n        </div>\n        <div data-kid=\"62\">\n          <div class=\"text-7xl lg:text-8xl font-black tracking-tighter text-[#1E2636]\" data-kid=\"63\">99.9%</div>\n          <p class=\"font-mono text-[10px] uppercase tracking-widest text-[#3E4A89] font-bold mt-3\" data-kid=\"64\">Error Margin Rate</p>\n        </div>\n      </div>\n\n      \n      <div class=\"flex-1 p-10 flex flex-col justify-between animate-slide-up hover:bg-white hover:translate-y-[-4px] transition-all duration-500\" style=\"animation-delay: 0.2s;\" data-kid=\"65\">\n        <div class=\"font-mono text-[10px] uppercase tracking-[0.3em] text-[#4A5578]/40 flex items-center justify-between\" data-kid=\"66\">\n          <span data-kid=\"67\">Scale</span>\n          <span class=\"opacity-0 group-hover/metrics:opacity-100 transition-opacity\" data-kid=\"68\">02</span>\n        </div>\n        <div data-kid=\"69\">\n          <div class=\"text-7xl lg:text-8xl font-black tracking-tighter text-[#1E2636]\" data-kid=\"70\">14K+</div>\n          <p class=\"font-mono text-[10px] uppercase tracking-widest text-[#3E4A89] font-bold mt-3\" data-kid=\"71\">Global Nodes Active</p>\n        </div>\n      </div>\n\n      \n      <div class=\"flex-1 p-10 flex flex-col justify-between animate-slide-up hover:bg-white hover:translate-y-[-4px] transition-all duration-500\" style=\"animation-delay: 0.3s;\" data-kid=\"72\">\n        <div class=\"font-mono text-[10px] uppercase tracking-[0.3em] text-[#4A5578]/40 flex items-center justify-between\" data-kid=\"73\">\n          <span data-kid=\"74\">Latency</span>\n          <span class=\"opacity-0 group-hover/metrics:opacity-100 transition-opacity\" data-kid=\"75\">03</span>\n        </div>\n        <div data-kid=\"76\">\n          <div class=\"text-7xl lg:text-8xl font-black tracking-tighter text-[#1E2636]\" data-kid=\"77\">0.4<span class=\"text-3xl\" data-kid=\"78\">ms</span></div>\n          <p class=\"font-mono text-[10px] uppercase tracking-widest text-[#3E4A89] font-bold mt-3\" data-kid=\"79\">P99 Response Time</p>\n        </div>\n      </div>\n\n      \n      <div class=\"flex-1 p-10 flex flex-col justify-between animate-slide-up hover:bg-white hover:translate-y-[-4px] transition-all duration-500\" style=\"animation-delay: 0.4s;\" data-kid=\"80\">\n        <div class=\"font-mono text-[10px] uppercase tracking-[0.3em] text-[#4A5578]/40 flex items-center justify-between\" data-kid=\"81\">\n          <span data-kid=\"82\">Availability</span>\n          <span class=\"opacity-0 group-hover/metrics:opacity-100 transition-opacity\" data-kid=\"83\">04</span>\n        </div>\n        <div data-kid=\"84\">\n          <div class=\"text-7xl lg:text-8xl font-black tracking-tighter text-[#1E2636]\" data-kid=\"85\">24/7</div>\n          <p class=\"font-mono text-[10px] uppercase tracking-widest text-[#3E4A89] font-bold mt-3\" data-kid=\"86\">Engineering Support</p>\n        </div>\n      </div>\n      \n    </div>\n\n    \n    <div class=\"absolute top-0 right-0 w-[40%] h-full border-l border-subtle -z-10 pointer-events-none\" data-kid=\"87\"></div>\n  </div>\n\n  \n  <div class=\"max-w-[1440px] mx-auto flex justify-between px-12 py-6 font-mono text-[9px] uppercase tracking-widest text-[#4A5578]/30\" data-kid=\"88\">\n    <span data-kid=\"89\">System Status: Optimal</span>\n    <span data-kid=\"90\">© 2024 Nexus Editorial Studio</span>\n  </div>\n</section>\n",
