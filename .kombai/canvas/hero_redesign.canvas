      "html": "\n<style data-kid=\"0\">\n  @import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;700;900&family=JetBrains+Mono:wght@400;700&family=Playfair+Display:ital,wght@1,300;1,400&display=swap');\n\n  :root {\n    --color-bg: #191E2F;\n    --color-primary: #3E4A89;\n    --color-primary-light: #9BA6D3;\n    --color-accent: #FAF8F5;\n  }\n\n  .font-sans { font-family: 'Inter', sans-serif; }\n  .font-mono { font-family: 'JetBrains Mono', monospace; }\n  .font-serif { font-family: 'Playfair Display', serif; }\n\n  .architectural-grid {\n    background-image: \n      linear-gradient(to right, rgba(255,255,255,0.05) 1px, transparent 1px),\n      linear-gradient(to bottom, rgba(255,255,255,0.05) 1px, transparent 1px);\n    background-size: 50px 50px;\n  }\n\n  .mask-linear {\n    -webkit-mask-image: linear-gradient(to bottom, transparent 0%, black 50%, transparent 100%);\n    mask-image: linear-gradient(to bottom, transparent 0%, black 50%, transparent 100%);\n  }\n\n  .text-extreme {\n    font-size: clamp(12rem, 30vw, 30rem);\n    line-height: 0.8;\n    letter-spacing: -0.05em;\n  }\n\n  @keyframes scan {\n    0% { transform: translateY(-100%); }\n    100% { transform: translateY(400%); }\n  }\n\n  .scan-line {\n    height: 1px;\n    background: linear-gradient(to right, transparent, rgba(255, 255, 255, 0.6), transparent);\n    width: 100%;\n    position: absolute;\n    top: 0;\n    left: 0;\n    z-index: 20;\n    animation: scan 4s linear infinite;\n  }\n\n  @keyframes bar-pulse {\n    0%, 100% { height: 20%; }\n    50% { height: 100%; }\n  }\n\n  .animate-bar {\n    animation: bar-pulse 1.5s ease-in-out infinite;\n    box-shadow: 0 0 15px rgba(155, 166, 211, 0.2);\n  }\n\n  .noise-overlay {\n    position: absolute;\n    inset: 0;\n    opacity: 0.05;\n    pointer-events: none;\n    z-index: 50;\n    background-image: url(\"data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noiseFilter'%3E%3CfeTurbulence