      "html": "\n<style data-kid=\"0\">\n  @import url('https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;1,400&family=Inter:wght@300;400;700;900&family=JetBrains+Mono:wght@400;700&display=swap');\n\n  :root {\n    --color-bg: #191E2F;\n    --color-primary: #3E4A89;\n    --color-primary-light: #9BA6D3;\n    --color-accent: #FAF8F5;\n  }\n\n  .font-display { font-family: 'Inter', sans-serif; }\n  .font-serif { font-family: 'Playfair Display', serif; }\n  .font-mono { font-family: 'JetBrains Mono', monospace; }\n\n  .architectural-grid {\n    background-image: \n      linear-gradient(to right, rgba(255,255,255,0.05) 1px, transparent 1px),\n      linear-gradient(to bottom, rgba(255,255,255,0.05) 1px, transparent 1px);\n    background-size: 60px 60px;\n  }\n\n  .glow-subtle {\n    box-shadow: 0 0 80px -20px rgba(62,74,137,0.3);\n  }\n\n  .text-extreme {\n    font-size: clamp(15rem, 30vw, 28rem);\n    line-height: 0.7;\n    letter-spacing: -0.07em;\n  }\n\n  .mask-linear {\n    mask-image: linear-gradient(to bottom, transparent 0%, black 50%, transparent 100%);\n  }\n</style>\n\n<div class=\"bg-[var(--color-bg)] text-[var(--color-accent)] min-h-[1000px] relative overflow-hidden font-display flex flex-col\" data-kid=\"1\">\n  \n  \n  <div class=\"absolute inset-0 architectural-grid pointer-events-none\" data-kid=\"2\"></div>\n  \n  \n  <div class=\"absolute inset-0 pointer-events-none opacity-20\" data-kid=\"3\">\n    <div class=\"absolute top-1/4 left-1/4 w-[500px] h-[500px] border border-white/10 rounded-full\" data-kid=\"4\"></div>\n    <div class=\"absolute top-1/3 left-1/2 w-[800px] h-[800px] border border-white/5 rounded-full -translate-x-1/2\" data-kid=\"5\"></div>\n    \n    <div class=\"absolute top-10 left-10 w-8 h-8 flex items-center justify-center\" data-kid=\"6\">\n      <div class=\"w-full h-[1px] bg-white/20\" data-kid=\"7\"></div>\n      <div class=\"h-full w-[1px] bg-white/20 absolute\" data-kid=\"8\"></div>\n    </div>\n    <div c