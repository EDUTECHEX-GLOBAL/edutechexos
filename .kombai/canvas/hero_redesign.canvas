center gap-4 text-[#D4AF37]/60 hover:text-[#D4AF37] transition-all cursor-pointer group/logo\" data-kid=\"145\">\n            <div class=\"w-12 h-12 flex items-center justify-center rounded-full border border-current\" data-kid=\"146\">\n              <i class=\"ti ti-world text-2xl\" data-kid=\"147\"></i>\n            </div>\n            <div class=\"flex flex-col\" data-kid=\"148\">\n              <span class=\"font-serif text-2xl font-bold tracking-tight\" data-kid=\"149\">EDUVISTA</span>\n              <span class=\"text-[8px] font-bold tracking-[0.2em] uppercase opacity-60\" data-kid=\"150\">International Research Hub</span>\n            </div>\n          </div>\n\n          <div class=\"flex items-center gap-4 text-[#D4AF37]/60 hover:text-[#D4AF37] transition-all cursor-pointer group/logo\" data-kid=\"151\">\n            <div class=\"w-12 h-12 flex items-center justify-center rounded-full border border-current\" data-kid=\"152\">\n              <i class=\"ti ti-certificate text-2xl\" data-kid=\"153\"></i>\n            </div>\n            <div class=\"flex flex-col\" data-kid=\"154\">\n              <span class=\"font-serif text-2xl font-bold tracking-tight\" data-kid=\"155\">PRINCETON</span>\n              <span class=\"text-[8px] font-bold tracking-[0.2em] uppercase opacity-60\" data-kid=\"156\">Center for Digital Excellence</span>\n            </div>\n          </div>\n        </div>\n      </div>\n    </div>\n  </section>\n</div>\n",
