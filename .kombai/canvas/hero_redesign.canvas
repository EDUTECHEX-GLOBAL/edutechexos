      "html": "<style data-kid=\"0\">\n  @import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Space+Grotesk:wght@500;600;700&display=swap');\n\n  .font-heading { font-family: 'Space Grotesk', sans-serif; }\n  .font-body { font-family: 'Inter', sans-serif; }\n\n  @keyframes reveal-up {\n    0% { opacity: 0; transform: translateY(40px) scale(0.98); }\n    100% { opacity: 1; transform: translateY(0) scale(1); }\n  }\n\n  .animate-reveal {\n    animation: reveal-up 1s cubic-bezier(0.16, 1, 0.3, 1) forwards;\n    opacity: 0;\n  }\n\n  .delay-1 { animation-delay: 0.1s; }\n  .delay-2 { animation-delay: 0.25s; }\n  .delay-3 { animation-delay: 0.4s; }\n  .delay-4 { animation-delay: 0.55s; }\n\n  .glow-indigo { filter: drop-shadow(0 0 15px rgba(79, 70, 229, 0.4)); }\n  .glow-green { filter: drop-shadow(0 0 10px rgba(34, 197, 94, 0.3)); }\n</style>\n\n<div class=\"font-body bg-[#1E293B] min-h-[950px] flex items-center justify-center p-6 lg:p-12\" data-kid=\"1\">\n  \n  <div class=\"max-w-[1440px] w-full grid grid-cols-10 gap-[1px] bg-slate-800 overflow-hidden rounded-[3rem] shadow-[0_48px_96px_-24px_rgba(0,0,0,0.6)] border border-slate-700\" data-kid=\"2\">\n    \n    \n    \n    <div class=\"col-span-10 lg:col-span-6 bg-[#FDFFFC] p-12 lg:p-24 flex flex-col justify-center animate-reveal delay-1 relative\" data-kid=\"3\">\n      <div class=\"inline-flex items-center gap-3 px-4 py-2 rounded-xl bg-[#E0E7FF] text-[#4F46E5] text-[10px] font-bold uppercase tracking-[0.2em] mb-12 w-fit\" data-kid=\"4\">\n        <span class=\"flex h-2 w-2 rounded-full bg-[#4F46E5] animate-pulse\" data-kid=\"5\"></span>\n        Educational Team Operating System\n      </div>\n      \n      <h1 class=\"font-heading text-6xl lg:text-[5.75rem] font-bold leading-[0.9] tracking-[-0.04em] text-[#1E293B] mb-12\" data-kid=\"6\">\n        The Team OS <br data-kid=\"7\"> \n        <span class=\"text-[#4F46E5] relative inline-block\" data-kid=\"8\">\n          EduTechEx\n          <span class=\"absolute -bottom-2 left-0 w-1/3 h-1.5 bg-[#4F46E5]/20 rounded-full\" data-kid=\"9\"></span>\n        </span> <br data-kid=\"10\">\n        Runs On.\n      </h1>\n      \n      <p class=\"text-xl lg:text-2xl text-slate-500 max-w-xl mb-14 leading-relaxed font-medium\" data-kid=\"11\">\n        Consolidate channels, AI intelligence, and task management into a high-performance workspace for edtech pioneers.\n      </p>\n      \n      <div class=\"flex flex-wrap items-center gap-6\" data-kid=\"12\">\n        <button class=\"px-12 py-5 bg-[#4F46E5] text-white rounded-2xl font-bold text-lg shadow-[0_20px_40px_-10px_rgba(79,70,229,0.35)] hover:scale-[1.02] hover:-translate-y-1 transition-all duration-300\" data-kid=\"13\">\n          Get Started\n        </button>\n        <button class=\"px-12 py-5 border-2 border-slate-200 text-slate-700 rounded-2xl font-bold text-lg hover:bg-slate-50 transition-all\" data-kid=\"14\">\n          Request Demo\n        </button>\n      </div>\n    </div>\n\n    \n    <div class=\"col-span-10 lg:col-span-4 bg-[#1E293B] relative flex flex-col items-center justify-center p-16 overflow-hidden animate-reveal delay-2 group\" data-kid=\"15\">\n      \n      <video src=\"https://videos.pexels.com/video-files/7101913/7101913-uhd_2560_1440_25fps.mp4\" poster=\"https://images.pexels.com/videos/7101913/abstract-abstract-background-abstract-form-abstract-particles-7101913.jpeg?auto=compress&cs=tinysrgb&fit=crop&h=630&w=1200\" autoplay muted loop playsinline preload=\"metadata\" class=\"absolute inset-0 w-full h-full object-cover opacity-30 scale-105 group-hover:scale-100 transition-transform duration-[3s]\" data-kid=\"16\"></video>\n      \n      <div class=\"absolute inset-0 bg-gradient-to-tr from-[#1E293B] via-transparent to-[#1E293B]/20 z-1\" data-kid=\"17\"></div>\n\n      \n      <div class=\"relative z-10 flex flex-col items-center text-center\" data-kid=\"18\">\n        <div class=\"w-28 h-28 rounded-[2.5rem] bg-[#4F46E5]/10 backdrop-blur-3xl border border-[#4F46E5]/20 flex items-center justify-center mb-12 glow-indigo\" data-kid=\"19\">\n          <svg xmlns=\"http://www.w3.org/2000/svg\" class=\"w-12 h-12 text-[#4F46E5]\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" data-kid=\"20\">\n            <path d=\"M12 3l1.912 5.886h6.188l-5.005 3.638 1.912 5.886-5.007-3.638-5.007 3.638 1.912-5.886-5.005-3.638h6.188z\" data-kid=\"21\"></path>\n            <path d=\"M5 3l.75 2.25l2.25 .75l-2.25 .75l-.75 2.25l-.75 -2.25l-2.25 -.75l2.25 -.75z\" data-kid=\"22\"></path>\n            <path d=\"M19 17l.75 2.25l2.25 .75l-2.25 .75l-.75 2.25l-.75 -2.25l-2.25 -.75l2.25 -.75z\" data-kid=\"23\"></path>\n          </svg>\n        </div>\n        <h3 class=\"font-heading text-3xl lg:text-4xl font-bold text-[#FDFFFC] mb-6 tracking-tight\" data-kid=\"24\">Intelligence Engine</h3>\n        <p class=\"text-slate-300 text-lg max-w-[300px] leading-relaxed font-medium\" data-kid=\"25\">\n          Automated extraction of meeting insights and task allocation from your daily conversations.\n        </p>\n        \n        \n        <div class=\"mt-16 flex flex-col items-center gap-4 w-full opacity-40\" data-kid=\"26\">\n          <div class=\"h-[1px] bg-gradient-to-r from-transparent via-[#4F46E5] to-transparent w-full\" data-kid=\"27\"></div>\n          <div class=\"h-[1px] bg-gradient-to-r from-transparent via-indigo-400 to-transparent w-2/3\" data-kid=\"28\"></div>\n        </div>\n      </div>\n    </div>\n\n    \n    \n    <div class=\"col-span-10 lg:col-span-3 bg-[#E0E7FF] p-12 flex flex-col justify-between animate-reveal delay-3 relative group\" data-kid=\"29\">\n      <div class=\"flex items-center gap-4 mb-14\" data-kid=\"30\">\n        <h4 class=\"font-heading font-bold text-[#1E293B] text-2xl tracking-tight\" data-kid=\"31\">Morning Digest</h4>\n        <div class=\"w-12 h-12 flex items-center justify-center transform group-hover:rotate-12 group-hover:scale-110 transition-all duration-500\" data-kid=\"32\">\n          <img src=\"https://cdn.jsdelivr.net/npm/openmoji-named-svgs@latest/color/hot-beverage.svg\" alt=\"Coffee\" class=\"w-full h-full drop-shadow-lg\" data-kid=\"33\">\n        </div>\n      </div>\n      \n      <div class=\"bg-white/90 backdrop-blur-2xl rounded-[2.5rem] p-9 shadow-[0_32px_64px_-16px_rgba(79,70,229,0.15)] border border-white/80 transform group-hover:-translate-y-2 transition-transform duration-500\" data-kid=\"34\">\n        <div class=\"flex items-center gap-4 mb-6\" data-kid=\"35\">\n          <div class=\"w-12 h-12 rounded-2xl bg-[#4F46E5] flex items-center justify-center shadow-lg shadow-indigo-500/20\" data-kid=\"36\">\n            <svg xmlns=\"http://www.w3.org/2000/svg\" class=\"w-6 h-6 text-white\" viewBox=\"0 0 24 24\" fill=\"currentColor\" data-kid=\"37\">\n              <path d=\"M12 2c3.866 0 7 3.134 7 7 0 3.328-2.31 6.117-5.4 6.843l-.6.136v4.021l1.172 1.171a1 1 0 0 1-1.414 1.415l-1.172-1.172-1.172 1.172a1 1 0 0 1-1.414-1.415l1.172-1.171v-4.021l-.6-.136c-3.09-.726-5.4-3.515-5.4-6.843 0-3.866 3.134-7 7-7z\" data-kid=\"38\"></path>\n            </svg>\n          </div>\n          <div data-kid=\"39\">\n            <p class=\"text-[10px] font-bold text-[#4F46E5] uppercase tracking-widest\" data-kid=\"40\">Today's Focus</p>\n            <p class=\"text-xs text-slate-500 font-bold\" data-kid=\"41\">08:00 AM • Wed</p>\n          </div>\n        </div>\n        <p class=\"text-base font-bold text-[#1E293B] leading-relaxed mb-6\" data-kid=\"42\">\n          \"The curriculum audit is 88% complete. 2 roadblocks identified in #development.\"\n        </p>\n        <div class=\"h-1.5 w-full bg-slate-100 rounded-full overflow-hidden\" data-kid=\"43\">\n          <div class=\"h-full bg-[#4F46E5] w-[88%] rounded-full\" data-kid=\"44\"></div>\n        </div>\n      </div>\n\n      <div class=\"mt-14 text-sm text-[#4F46E5] font-bold flex items-center gap-3 cursor-pointer group/link\" data-kid=\"45\">\n        Read Full Synthesis \n        <svg xmlns=\"http://www.w3.org/2000/svg\" class=\"w-5 h-5 group-hover/link:translate-x-1 transition-transform\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"3\" stroke-linecap=\"round\" stroke-linejoin=\"round\" data-kid=\"46\">\n          <line x1=\"5\" y1=\"12\" x2=\"19\" y2=\"12\" data-kid=\"47\"></line>\n          <polyline points=\"12 5 19 12 12 19\" data-kid=\"48\"></polyline>\n        </svg>\n      </div>\n    </div>\n\n    \n    <div class=\"col-span-10 lg:col-span-7 bg-[#FDFFFC] p-12 lg:p-16 flex flex-col lg:flex-row gap-20 animate-reveal delay-4\" data-kid=\"49\">\n      \n      \n      <div class=\"flex-1\" data-kid=\"50\">\n        <div class=\"flex items-center justify-between mb-12\" data-kid=\"51\">\n          <h4 class=\"font-heading font-bold text-[#1E293B] text-2xl tracking-tight\" data-kid=\"52\">Active Pulse</h4>\n          <span class=\"px-4 py-1.5 rounded-full bg-emerald-50 text-emerald-600 text-[10px] font-bold border border-emerald-100 uppercase tracking-widest shadow-sm\" data-kid=\"53\">Online</span>\n        </div>\n        \n        <div class=\"flex flex-col gap-10\" data-kid=\"54\">\n          \n          <div class=\"flex -space-x-5\" data-kid=\"55\">\n            <img class=\"w-16 h-16 rounded-[1.25rem] border-4 border-white shadow-xl object-cover\" src=\"https://i.pravatar.cc/150?u=sarah\" alt=\"Avatar\" data-kid=\"56\">\n            <img class=\"w-16 h-16 rounded-[1.25rem] border-4 border-white shadow-xl object-cover\" src=\"https://i.pravatar.cc/150?u=mike\" alt=\"Avatar\" data-kid=\"57\">\n            <img class=\"w-16 h-16 rounded-[1.25rem] border-4 border-white shadow-xl object-cover\" src=\"https://i.pravatar.cc/150?u=jenny\" alt=\"Avatar\" data-kid=\"58\">\n            <img class=\"w-16 h-16 rounded-[1.25rem] border-4 border-white shadow-xl object-cover\" src=\"https://i.pravatar.cc/150?u=oscar\" alt=\"Avatar\" data-kid=\"59\">\n            <div class=\"w-16 h-16 rounded-[1.25rem] border-4 border-white bg-slate-50 flex items-center justify-center text-xs font-bold text-slate-500 shadow-xl\" data-kid=\"60\">+18</div>\n          </div>\n\n          \n          <div class=\"space-y-4\" data-kid=\"61\">\n            <div class=\"p-5 bg-slate-50 rounded-[1.5rem] flex items-center justify-between border border-slate-100 hover:bg-white hover:border-[#4F46E5]/20 hover:shadow-xl transition-all cursor-pointer group\" data-kid=\"62\">\n              <div class=\"flex items-center gap-5\" data-kid=\"63\">\n                <div class=\"w-3.5 h-3.5 rounded-full bg-[#4F46E5] shadow-[0_0_12px_rgba(79,70,229,0.5)]\" data-kid=\"64\"></div>\n                <span class=\"text-lg font-bold text-slate-800\" data-kid=\"65\">#product-vision</span>\n              </div>\n              <svg xmlns=\"http://www.w3.org/2000/svg\" class=\"w-6 h-6 text-slate-300 group-hover:text-[#4F46E5] transition-colors\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2.5\" stroke-linecap=\"round\" stroke-linejoin=\"round\" data-kid=\"66\">\n                <polyline points=\"9 18 15 12 9 6\" data-kid=\"67\"></polyline>\n              </svg>\n            </div>\n            <div class=\"p-5 bg-slate-50 rounded-[1.5rem] flex items-center justify-between border border-slate-100 opacity-40 grayscale transition-all hover:grayscale-0 hover:opacity-100\" data-kid=\"68\">\n              <div class=\"flex items-center gap-5\" data-kid=\"69\">\n                <div class=\"w-3.5 h-3.5 rounded-full bg-slate-300\" data-kid=\"70\"></div>\n                <span class=\"text-lg font-bold text-slate-800\" data-kid=\"71\">#ops-deployment</span>\n              </div>\n            </div>\n          </div>\n        </div>\n      </div>\n\n      \n      <div class=\"hidden lg:block w-[1px] bg-slate-100 h-full\" data-kid=\"72\"></div>\n\n      \n      <div class=\"flex-1\" data-kid=\"73\">\n        <h4 class=\"font-heading font-bold text-[#1E293B] text-2xl tracking-tight mb-12\" data-kid=\"74\">Task Extraction</h4>\n        \n        <div class=\"space-y-6\" data-kid=\"75\">\n          \n          <div class=\"flex items-start gap-5 p-6 rounded-[2rem] hover:bg-emerald-50/50 transition-all group\" data-kid=\"76\">\n            <div class=\"mt-1\" data-kid=\"77\">\n              <svg xmlns=\"http://www.w3.org/2000/svg\" class=\"w-8 h-8 text-emerald-500 glow-green\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2.5\" stroke-linecap=\"round\" stroke-linejoin=\"round\" data-kid=\"78\">\n                <circle cx=\"12\" cy=\"12\" r=\"10\" data-kid=\"79\"></circle>\n                <path d=\"M9 12l2 2l4 -4\" data-kid=\"80\"></path>\n              </svg>\n            </div>\n            <div data-kid=\"81\">\n              <p class=\"text-lg font-bold text-slate-800 leading-tight mb-1.5\" data-kid=\"82\">Finalize Q3 Learning API</p>\n              <p class=\"text-[11px] text-slate-400 font-bold uppercase tracking-[0.05em]\" data-kid=\"83\">Extracted from #dev-general</p>\n            </div>\n          </div>\n          \n          \n          <div class=\"flex items-start gap-5 p-6 rounded-[2rem] hover:bg-emerald-50/50 transition-all group opacity-85\" data-kid=\"84\">\n            <div class=\"mt-1\" data-kid=\"85\">\n              <svg xmlns=\"http://www.w3.org/2000/svg\" class=\"w-8 h-8 text-emerald-500 glow-green\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2.5\" stroke-linecap=\"round\" stroke-linejoin=\"round\" data-kid=\"86\">\n                <circle cx=\"12\" cy=\"12\" r=\"10\" data-kid=\"87\"></circle>\n                <path d=\"M9 12l2 2l4 -4\" data-kid=\"88\"></path>\n              </svg>\n            </div>\n            <div data-kid=\"89\">\n              <p class=\"text-lg font-bold text-slate-800 leading-tight mb-1.5\" data-kid=\"90\">Audit User Security Patch</p>\n              <p class=\"text-[11px] text-slate-400 font-bold uppercase tracking-[0.05em]\" data-kid=\"91\">Urgent • Context: AI-Tagged</p>\n            </div>\n          </div>\n\n          \n          <div class=\"flex items-start gap-5 p-6 rounded-[2rem] border-2 border-dashed border-slate-100 hover:border-[#4F46E5] hover:bg-indigo-50/30 transition-all cursor-pointer group\" data-kid=\"92\">\n            <div class=\"w-8 h-8 rounded-full border-2 border-slate-200 group-hover:border-[#4F46E5] flex items-center justify-center transition-colors\" data-kid=\"93\">\n              <svg xmlns=\"http://www.w3.org/2000/svg\" class=\"w-5 h-5 text-slate-300 group-hover:text-[#4F46E5]\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"3\" stroke-linecap=\"round\" stroke-linejoin=\"round\" data-kid=\"94\">\n                <line x1=\"12\" y1=\"5\" x2=\"12\" y2=\"19\" data-kid=\"95\"></line>\n                <line x1=\"5\" y1=\"12\" x2=\"19\" y2=\"12\" data-kid=\"96\"></line>\n              </svg>\n            </div>\n            <div data-kid=\"97\">\n              <p class=\"text-lg font-bold text-slate-800 leading-tight group-hover:text-[#4F46E5] transition-colors\" data-kid=\"98\">Add Custom Task</p>\n              <p class=\"text-xs text-slate-400 font-medium\" data-kid=\"99\">Auto-extraction remains active</p>\n            </div>\n          </div>\n        </div>\n      </div>\n\n    </div>\n  </div>\n</div>\n",
