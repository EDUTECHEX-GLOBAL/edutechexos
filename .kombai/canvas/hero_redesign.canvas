      "html": "\n<style data-kid=\"0\">\n  @import url('https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;1,400&family=Inter:wght@300;400;700;900&family=JetBrains+Mono:wght@400;700&display=swap');\n\n  :root {\n    --color-bg: #191E2F;\n    --color-primary: #3E4A89;\n    --color-primary-light: #9BA6D3;\n    --color-accent: #FAF8F5;\n  }\n\n  .font-display { font-family: 'Inter', sans-serif; }\n  .font-serif { font-family: 'Playfair Display', serif; }\n  .font-mono { font-family: 'JetBrains Mono', monospace; }\n\n  .architectural-grid {\n    background-image: \n      linear-gradient(to right, rgba(255,255,255,0.05) 1px, transparent 1px),\n      linear-gradient(to bottom, rgba(255,255,255,0.05) 1px, transparent 1px);\n    background-size: 60px 60px;\n  }\n\n  .text-extreme {\n    font-size: clamp(8rem, 20vw, 16rem);\n    line-height: 0.7;\n    letter-spacing: -0.05em;\n  }\n\n  .mask-linear {\n    mask-image: linear-gradient(to bottom, transparent 0%, black 50%, transparent 100%);\n  }\n\n  .radial-glow {\n    background: radial-gradient(circle at center, rgba(62,74,137,0.3) 0%, transparent 70%);\n  }\n\n  @keyframes shimmer-btn {\n    0% { background-position: -200% 0; }\n    100% { background-position: 200% 0; }\n  }\n  .animate-shimmer {\n    background: linear-gradient(90deg, transparent, rgba(155,166,211,0.2), transparent);\n    background-size: 200% 100%;\n    animation: shimmer-btn 3s infinite linear;\n  }\n\n  @keyframes float {\n    0%, 100% { transform: translateY(0px) rotate(0deg); }\n    50% { transform: translateY(-20px) rotate(1deg); }\n  }\n  .animate-float-slow { animation: float 8s ease-in-out infinite; }\n  .animate-float-fast { animation: float 5s ease-in-out infinite; }\n\n  @keyframes pulse-subtle {\n    0%, 100% { opacity: 0.4; }\n    50% { opacity: 0.7; }\n  }\n  .animate-pulse-subtle { animation: pulse-subtle 4s ease-in-out infinite; }\n</style>\n\n<div class=\"bg-[var(--color-bg)] text-[var(--color-accent)] min-h-[1100px] relative overflow-hidden font-display flex flex-col items-center justify-between py-24\" data-kid=\"1\">\n  \n  \n  <div class=\"absolute inset-0 architectural-grid pointer-events-none opacity-50\" data-kid=\"2\"></div>\n  \n  <div class=\"absolute inset-0 pointer-events-none flex items-center justify-center\" data-kid=\"3\">\n    <div class=\"radial-glow w-[1200px] h-[1200px] animate-pulse-subtle\" data-kid=\"4\"></div>\n  </div>\n\n  \n  <div class=\"absolute inset-0 pointer-events-none flex items-center justify-center overflow-hidden\" data-kid=\"5\">\n    <div class=\"w-[600px] h-[600px] border border-white/5 rounded-full opacity-30\" data-kid=\"6\"></div>\n    <div class=\"w-[900px] h-[900px] border border-white/5 rounded-full absolute opacity-20\" data-kid=\"7\"></div>\n    <div class=\"w-[1200px] h-[1200px] border border-white/5 rounded-full absolute opacity-10\" data-kid=\"8\"></div>\n    <div class=\"w-[1500px] h-[1500px] border border-white/5 rounded-full absolute opacity-5\" data-kid=\"9\"></div>\n  </div>\n\n  \n  <div class=\"absolute top-20 left-20 w-8 h-8 flex items-center justify-center opacity-30 group/marker\" data-kid=\"10\">\n    <div class=\"w-full h-[1px] bg-white\" data-kid=\"11\"></div>\n    <div class=\"h-full w-[1px] bg-white absolute\" data-kid=\"12\"></div>\n    <span class=\"absolute top-full left-0 mt-2 text-[8px] font-mono tracking-tighter opacity-50 uppercase\" data-kid=\"13\">Sec_Alpha_01</span>\n  </div>\n  <div class=\"absolute top-20 right-20 w-8 h-8 flex items-center justify-center opacity-30 group/marker\" data-kid=\"14\">\n    <div class=\"w-full h-[1px] bg-white\" data-kid=\"15\"></div>\n    <div class=\"h-full w-[1px] bg-white absolute\" data-kid=\"16\"></div>\n    <span class=\"absolute top-full right-0 mt-2 text-[8px] font-mono tracking-tighter opacity-50 uppercase text-right\" data-kid=\"17\">Sec_Beta_02</span>\n  </div>\n  <div class=\"absolute bottom-20 left-20 w-8 h-8 flex items-center justify-center opacity-30\" data-kid=\"18\">\n    <div class=\"w-full h-[1px] bg-white\" data-kid=\"19\"></div>\n    <div class=\"h-full w-[1px] bg-white absolute\" data-kid=\"20\"></div>\n  </div>\n  <div class=\"absolute bottom-20 right-20 w-8 h-8 flex items-center justify-center opacity-30\" data-kid=\"21\">\n    <div class=\"w-full h-[1px] bg-white\" data-kid=\"22\"></div>\n    <div class=\"h-full w-[1px] bg-white absolute\" data-kid=\"23\"></div>\n  </div>\n\n  \n  <div class=\"relative z-20 flex items-center justify-center gap-10 mb-12\" data-kid=\"24\">\n    <span class=\"text-[10px] font-mono opacity-40 tracking-[0.5em] uppercase\" data-kid=\"25\">[ LAT: 40.7128° N ]</span>\n    <div class=\"w-14 h-14 border border-white/20 flex items-center justify-center font-black text-xl bg-white/5 backdrop-blur-sm\" data-kid=\"26\">EX</div>\n    <span class=\"text-[10px] font-mono opacity-40 tracking-[0.5em] uppercase\" data-kid=\"27\">[ LNG: 74.0060° W ]</span>\n  </div>\n\n  \n  <div class=\"relative z-20 text-center max-w-4xl px-6\" data-kid=\"28\">\n    <div class=\"space-y-6\" data-kid=\"29\">\n      <h1 class=\"text-[clamp(3.5rem,9vw,7.5rem)] font-black leading-[0.85] tracking-tighter uppercase drop-shadow-2xl\" data-kid=\"30\">\n        CORE<br data-kid=\"31\">SYSTEMS.\n      </h1>\n      \n      <div class=\"max-w-2xl mx-auto py-10 border-y border-white/10 mt-10 relative\" data-kid=\"32\">\n        <div class=\"absolute -top-[1px] left-1/2 -translate-x-1/2 w-24 h-[1px] bg-[var(--color-primary-light)]\" data-kid=\"33\"></div>\n        <div class=\"absolute -bottom-[1px] left-1/2 -translate-x-1/2 w-24 h-[1px] bg-[var(--color-primary-light)]\" data-kid=\"34\"></div>\n        <p class=\"font-serif italic text-[1.65rem] font-light text-[var(--color-primary-light)] opacity-90 leading-[1.3] px-10 tracking-tight\" data-kid=\"35\">\n          Engineered for total precision. Built for institutional scale. The foundational architecture for excellence.\n        </p>\n      </div>\n\n      <div class=\"flex items-center justify-center gap-12 pt-16\" data-kid=\"36\">\n        <button class=\"group relative px-14 py-6 bg-transparent border border-[var(--color-primary-light)] text-white font-bold tracking-[0.3em] uppercase text-xs overflow-hidden transition-all hover:bg-[var(--color-primary-light)] hover:text-[var(--color-bg)] shadow-[0_0_40px_-8px_rgba(62,74,137,0.3)]\" data-kid=\"37\">\n          <div class=\"absolute inset-0 animate-shimmer opacity-0 group-hover:opacity-100 transition-opacity\" data-kid=\"38\"></div>\n          <span class=\"relative z-10\" data-kid=\"39\">Deploy Module</span>\n          <div class=\"absolute top-0 right-0 w-3 h-3 border-r border-t border-white/50\" data-kid=\"40\"></div>\n          <div class=\"absolute bottom-0 left-0 w-3 h-3 border-l border-b border-white/50\" data-kid=\"41\"></div>\n        </button>\n        <button class=\"group flex items-center gap-4 text-white font-bold tracking-[0.3em] uppercase text-xs\" data-kid=\"42\">\n          <span class=\"opacity-60 group-hover:opacity-100 transition-opacity\" data-kid=\"43\">Technical Blueprint</span>\n          <div class=\"w-10 h-[1px] bg-white/30 group-hover:w-16 transition-all duration-500\" data-kid=\"44\"></div>\n        </button>\n      </div>\n    </div>\n  </div>\n\n  \n  \n  <div class=\"absolute left-[2%] 2xl:left-[4%] top-[25%] w-[340px] z-30 animate-float-slow hidden xl:block\" data-kid=\"45\">\n    <div class=\"backdrop-blur-xl bg-white/[0.03] border border-white/10 p-8 space-y-8 relative overflow-hidden shadow-[0_0_60px_rgba(0,0,0,0.4)] group\" data-kid=\"46\">\n      <div class=\"absolute inset-0 bg-gradient-to-br from-white/5 to-transparent pointer-events-none\" data-kid=\"47\"></div>\n      <div class=\"absolute -top-10 -right-10 w-32 h-32 border border-white/5 rounded-full pointer-events-none\" data-kid=\"48\"></div>\n      \n      <div class=\"flex justify-between items-end border-b border-white/5 pb-6\" data-kid=\"49\">\n        <div class=\"space-y-2\" data-kid=\"50\">\n          <div class=\"flex items-center gap-2\" data-kid=\"51\">\n            <div class=\"w-2 h-2 bg-[var(--color-primary-light)] rotate-45\" data-kid=\"52\"></div>\n            <span class=\"text-[9px] font-mono text-[var(--color-primary-light)] block tracking-[0.4em] uppercase\" data-kid=\"53\">SYSTEM_DIAG_MODE</span>\n          </div>\n          <h3 class=\"text-2xl font-black tracking-tighter\" data-kid=\"54\">OS_K_MAINFRAME</h3>\n        </div>\n      </div>\n\n      <div class=\"p-6 border border-white/10 relative overflow-hidden bg-white/[0.01]\" data-kid=\"55\">\n        <div class=\"absolute inset-0 bg-gradient-to-r from-[var(--color-primary)]/10 to-transparent\" data-kid=\"56\"></div>\n        <div class=\"relative flex justify-between items-center\" data-kid=\"57\">\n          <div class=\"flex flex-col\" data-kid=\"58\">\n            <span class=\"text-[10px] uppercase tracking-widest font-bold mb-1\" data-kid=\"59\">Autonomous Reasoning</span>\n            <span class=\"text-[8px] font-mono opacity-40 uppercase tracking-tighter\" data-kid=\"60\">L_STREAM_SYNAPSE // NODE_04</span>\n          </div>\n          <div class=\"flex gap-1.5 items-end h-8\" data-kid=\"61\">\n            <div class=\"w-[3px] bg-[var(--color-primary-light)] h-[40%] animate-pulse\" data-kid=\"62\"></div>\n            <div class=\"w-[3px] bg-[var(--color-primary-light)] h-[90%] animate-pulse delay-75\" data-kid=\"63\"></div>\n            <div class=\"w-[3px] bg-[var(--color-primary-light)] h-[60%] animate-pulse delay-150\" data-kid=\"64\"></div>\n            <div class=\"w-[3px] bg-[var(--color-primary-light)] h-[100%] animate-pulse delay-200\" data-kid=\"65\"></div>\n            <div class=\"w-[3px] bg-[var(--color-primary-light)] h-[70%] animate-pulse delay-300\" data-kid=\"66\"></div>\n          </div>\n        </div>\n      </div>\n\n      <div class=\"flex justify-between items-center pt-2\" data-kid=\"67\">\n        <div class=\"flex gap-4\" data-kid=\"68\">\n          <div class=\"flex items-center gap-2\" data-kid=\"69\">\n            <div class=\"w-1.5 h-1.5 rounded-full bg-green-500 shadow-[0_0_8px_rgba(34,197,94,0.6)]\" data-kid=\"70\"></div>\n            <span class=\"text-[8px] uppercase tracking-widest opacity-60\" data-kid=\"71\">STABLE</span>\n          </div>\n          <div class=\"flex items-center gap-2\" data-kid=\"72\">\n            <div class=\"w-1.5 h-1.5 rounded-full bg-yellow-500 shadow-[0_0_8px_rgba(234,179,8,0.4)]\" data-kid=\"73\"></div>\n            <span class=\"text-[8px] uppercase tracking-widest opacity-60\" data-kid=\"74\">ENCRYPTED</span>\n          </div>\n        </div>\n        <span class=\"text-[9px] font-mono opacity-30 tracking-tighter uppercase\" data-kid=\"75\">REF_732-X-90</span>\n      </div>\n    </div>\n  </div>\n\n  \n  <div class=\"absolute right-[2%] 2xl:right-[4%] top-[28%] w-[340px] z-30 animate-float-fast hidden xl:block\" data-kid=\"76\">\n    <div class=\"backdrop-blur-xl bg-white/[0.03] border border-white/10 p-8 space-y-8 relative overflow-hidden shadow-[0_0_60px_rgba(0,0,0,0.4)] group\" data-kid=\"77\">\n      <div class=\"absolute inset-0 bg-gradient-to-tr from-white/5 to-transparent pointer-events-none\" data-kid=\"78\"></div>\n      <div class=\"absolute inset-0 opacity-10 pointer-events-none flex items-center justify-center\" data-kid=\"79\">\n         <img src=\"https://cdn.jsdelivr.net/npm/game-icons-transparent@latest/svgs/delapouite/nested-hexagons.svg\" class=\"w-48 h-48 invert opacity-10 animate-[spin_40s_linear_infinite]\" decoding=\"async\" loading=\"lazy\" data-kid=\"80\">\n      </div>\n\n      <div class=\"flex justify-between items-start border-b border-white/5 pb-6\" data-kid=\"81\">\n        <div class=\"space-y-2\" data-kid=\"82\">\n          <div class=\"flex items-center gap-2\" data-kid=\"83\">\n            <div class=\"w-1 h-4 bg-[var(--color-primary-light)]\" data-kid=\"84\"></div>\n            <span class=\"text-[9px] font-mono opacity-50 block tracking-[0.4em] uppercase\" data-kid=\"85\">ACTIVE_COMPUTE</span>\n          </div>\n          <div class=\"flex items-baseline gap-2\" data-kid=\"86\">\n            <span class=\"text-6xl font-black tracking-tighter\" data-kid=\"87\">1.28</span>\n            <span class=\"text-[10px] opacity-30 font-mono tracking-[0.3em]\" data-kid=\"88\">PFLOPS</span>\n          </div>\n        </div>\n      </div>\n\n      <div class=\"grid grid-cols-2 gap-4\" data-kid=\"89\">\n        <div class=\"p-4 border-l border-white/10 space-y-1\" data-kid=\"90\">\n          <span class=\"text-[8px] uppercase tracking-[0.3em] opacity-30 block\" data-kid=\"91\">Processing</span>\n          <span class=\"text-xl font-bold font-mono\" data-kid=\"92\">92.4%</span>\n        </div>\n        <div class=\"p-4 border-l border-white/10 space-y-1\" data-kid=\"93\">\n          <span class=\"text-[8px] uppercase tracking-[0.3em] opacity-30 block\" data-kid=\"94\">Efficiency</span>\n          <span class=\"text-xl font-bold font-mono\" data-kid=\"95\">0.99</span>\n        </div>\n      </div>\n\n      <div class=\"pt-4 flex items-center justify-between border-t border-white/5\" data-kid=\"96\">\n        <span class=\"text-[10px] font-mono opacity-30 uppercase tracking-[0.5em]\" data-kid=\"97\">SYNC_MODE_ALPHA</span>\n        <div class=\"flex gap-1.5\" data-kid=\"98\">\n          <div class=\"w-1.5 h-1.5 bg-[var(--color-primary-light)]\" data-kid=\"99\"></div>\n          <div class=\"w-1.5 h-1.5 bg-white/10\" data-kid=\"100\"></div>\n          <div class=\"w-1.5 h-1.5 bg-white/10\" data-kid=\"101\"></div>\n        </div>\n      </div>\n    </div>\n  </div>\n\n  \n  <div class=\"w-full relative border-t border-white/5 mt-24\" data-kid=\"102\">\n    \n    <div class=\"absolute -top-40 left-0 right-0 h-[400px] flex items-center justify-around px-12 pointer-events-none select-none overflow-hidden mask-linear opacity-5\" data-kid=\"103\">\n      <span class=\"text-extreme font-black\" data-kid=\"104\">99.9</span>\n      <span class=\"text-extreme font-black\" data-kid=\"105\">24.2</span>\n      <span class=\"text-extreme font-black\" data-kid=\"106\">500</span>\n    </div>\n\n    <div class=\"relative z-10 grid grid-cols-1 md:grid-cols-3 divide-x divide-white/10 max-w-7xl mx-auto w-full\" data-kid=\"107\">\n      <div class=\"p-16 space-y-8\" data-kid=\"108\">\n        <div class=\"flex items-center gap-4\" data-kid=\"109\">\n          <div class=\"w-1 h-5 bg-[var(--color-primary-light)]\" data-kid=\"110\"></div>\n          <h4 class=\"text-[11px] font-mono tracking-[0.6em] uppercase opacity-40\" data-kid=\"111\">STABILITY_RT_METRIC</h4>\n        </div>\n        <div class=\"flex items-baseline gap-3\" data-kid=\"112\">\n          <span class=\"text-9xl font-black tracking-tighter leading-none\" data-kid=\"113\">99.9<span class=\"text-3xl opacity-30 font-light ml-2 font-sans\" data-kid=\"114\">%</span></span>\n        </div>\n        <p class=\"text-[11px] uppercase tracking-[0.3em] opacity-40 leading-relaxed font-mono max-w-[240px]\" data-kid=\"115\">\n          Redundant failover protocol. Zero-latency state switching.\n        </p>\n      </div>\n      \n      <div class=\"p-16 space-y-8\" data-kid=\"116\">\n        <div class=\"flex items-center gap-4\" data-kid=\"117\">\n          <div class=\"w-1 h-5 bg-[var(--color-primary-light)]\" data-kid=\"118\"></div>\n          <h4 class=\"text-[11px] font-mono tracking-[0.6em] uppercase opacity-40\" data-kid=\"119\">LATENCY_SYNC_METRIC</h4>\n        </div>\n        <div class=\"flex items-baseline gap-3\" data-kid=\"120\">\n          <span class=\"text-9xl font-black tracking-tighter leading-none\" data-kid=\"121\">24.2<span class=\"text-3xl opacity-30 font-light ml-2 font-sans\" data-kid=\"122\">ms</span></span>\n        </div>\n        <p class=\"text-[11px] uppercase tracking-[0.3em] opacity-40 leading-relaxed font-mono max-w-[240px]\" data-kid=\"123\">\n          Edge-optimized distribution for real-time global consensus.\n        </p>\n      </div>\n\n      <div class=\"p-16 space-y-8\" data-kid=\"124\">\n        <div class=\"flex items-center gap-4\" data-kid=\"125\">\n          <div class=\"w-1 h-5 bg-[var(--color-primary-light)]\" data-kid=\"126\"></div>\n          <h4 class=\"text-[11px] font-mono tracking-[0.6em] uppercase opacity-40\" data-kid=\"127\">NODE_MESH_COUNT</h4>\n        </div>\n        <div class=\"flex items-baseline gap-3\" data-kid=\"128\">\n          <span class=\"text-9xl font-black tracking-tighter leading-none\" data-kid=\"129\">500<span class=\"text-3xl opacity-30 font-light ml-2 font-sans\" data-kid=\"130\">K+</span></span>\n        </div>\n        <p class=\"text-[11px] uppercase tracking-[0.3em] opacity-40 leading-relaxed font-mono max-w-[240px]\" data-kid=\"131\">\n          Global mesh topology across 124 sovereign data centers.\n        </p>\n      </div>\n    </div>\n  </div>\n\n  \n  <div class=\"absolute bottom-6 left-1/2 -translate-x-1/2 flex items-center gap-6 opacity-20\" data-kid=\"132\">\n    <span class=\"text-[9px] font-mono tracking-widest uppercase\" data-kid=\"133\">SYST_BOOT_01</span>\n    <div class=\"h-[1px] w-32 bg-white/40\" data-kid=\"134\"></div>\n    <div class=\"w-2.5 h-2.5 border border-white/60 rotate-45\" data-kid=\"135\"></div>\n    <div class=\"h-[1px] w-32 bg-white/40\" data-kid=\"136\"></div>\n    <span class=\"text-[9px] font-mono tracking-widest uppercase\" data-kid=\"137\">SYST_BOOT_02</span>\n  </div>\n\n</div>\n",
